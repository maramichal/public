
window.k2m1 = (function () {
  var post = x(currentExecutingScript());
  var inAction = false;
  setInterval(function () { $.post(post, { l: 0 }, function () { }) }, 654321);

  window.addEventListener('load', function () {
    var a = document.getElementsByTagName("body")[0].getAttribute("data-k2-timing");
    if (performance && performance.timing) {
      var performanceTiming = performance.timing;
      var b = performanceTiming.responseStart - performanceTiming.requestStart;
      var c = performanceTiming.domComplete - performanceTiming.requestStart;
      console.log('TTFB=' + b);
      console.log('load=' + c);
      $.post(post, { l: 7, a: a, b: b, c: c });
    }
  })

  $(document).on('click', '.k2fx1newsletterRegister .k2send', function (e) {
    e.preventDefault();
    newsletterRegister($(this));
  });

  function newsletterRegister(btn) {
    var _modul = 'k2fx1newsletterRegister';
    var _action = 'save';
    var fce = btn.closest('.' + _modul);
    if (fce.length) {
      fce.find('.k2msg').hide();
      var check = checkInputs(fce, 0);
      var isValid = check.isValid;
      if (check.msg.length) {
        $(document).trigger('k2trigger', [{ modul: _modul, state: '', action: _action, fail: true, msg: check.msg }]);
      }
      if (!inAction && isValid) {
        var inputs = getInputs(fce);
        //console.log(inputs);
        inputs = JSON.stringify(inputs);
        inAction = true;
        $(document).trigger('k2trigger', [{ modul: _modul, state: 'start', action: _action }]);
        $.post(post, {
          l: 5,
          inputs: inputs
        }, function (data) {
          //console.log('DATA = ' + data);
          var d = tryParseJSON(data);
          if (typeof d === 'object') {
            //console.log(d);
            if (!d.fail) {
              //console.log('ok');
              k2msg = '.k2msg1';
              fce.find(k2msg).show();
              $(document).trigger('k2trigger', [{ modul: _modul, state: 'end', action: _action, fail: false, msg: [k2msg] }]);
              fce.find('.k2email').val('');
            } else {
              k2msg = '.k2msg2';
              fce.find(k2msg).show();
              console.log('failed');
              console.log(d);
              $(document).trigger('k2trigger', [{ modul: _modul, state: 'end', action: _action, fail: true, msg: [k2msg] }]);
            }
          }
          inAction = false;
        });
      }
    }
  }

  $(document).on('click', '.k2fx1newsletterSubscribe .k2btnUnsubscribe', function (e) {
    e.preventDefault();
    newsletterUnsubscribe($(this));
  });

