                var markerp = "";

                znackyList.forEach(function (marker) {
                    if (marker._id == markerid) {
                        markerp = marker;
                    }
                });
                if (markerp != "") {
                    var arrayp = [];
                    arrayp.push(markerp._coords);

                    var cz = mapa.computeCenterZoom(arrayp); /* Spočítat pozici mapy tak, aby značky byly vidět */
