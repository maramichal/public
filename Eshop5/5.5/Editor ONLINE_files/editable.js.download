function isNeedSave(e) {
    if (e !== undefined) {
        e.classList.add('k2editableContentChanged');
    }
    if (!needSave) {
        needSave = true;
        document.querySelector('.editable_save').removeAttribute('disabled');
        if (!editingInK2) {
            window.onbeforeunload = function () {
                //document.body.innerHTML = location.href;
                return 'If you close this page you will lose your stride update!';
            };
        }

    }

    if (document.querySelector('.edit_table.active')) {
        document.querySelector('.edit_table.active').classList.remove('active');
    }
}


// přesouvaní sekcí
function moveContent() {

    var widthWindow = window.innerWidth,
        thisActive,
        thisActiveRect,
        lastY;

    window.addEventListener("resize", function () {
        widthWindow = window.innerWidth;
    });

    /*  addListenerMulti(elm, 'mousedown touchstart', moveBeforeStart);
      addListenerMulti(document, 'mouseup touchend', moveStopItem);*/

    if (pageConts) {
        pageConts.addEventListener('mousedown', moveBeforeStart);
    }


    /* var items = document.querySelectorAll('.html_container_edit'),
             itemsLength = items.length;
         for (i = 0; i < itemsLength; i++) {
             var t = items[i];
             t.removeEventListener("mousedown", moveBeforeStart, false);
             t.removeEventListener("touchstart", moveBeforeStart, false);
             t.removeEventListener("mouseup", moveStopItem, false);
             t.removeEventListener("touchend", moveStopItem, false);
         }*/


    function moveBeforeStart(event) {
        if (isChangeMove) {
            thisActive = document.elementFromPoint((widthWindow / 2), event.clientY);
            thisActiveRect = thisActive.getBoundingClientRect();
            var ghostElementActive = document.createElement('div');


            ghostElementActive.classList.add('ghost_move');
            ghostElementActive.style.height = thisActiveRect.height + 'px';


            thisActive.insertAdjacentHTML('beforeBegin', ghostElementActive.outerHTML);
            thisActive.classList.add('moving');


            thisActive.style.width = thisActiveRect.width + 'px';
            thisActive.style.left = thisActiveRect.left + 'px';
            thisActive.style.top = (event.clientY - (thisActiveRect.height / 2)) + 'px';
            thisActive.style.position = 'fixed';


            addListenerMulti(document, 'mousemove touchmove', moveStartItem);
            document.addEventListener('mouseup', moveStopItem);
        }
    }

    function moveStopItem(event) {
        event.preventDefault();

        //console.log(thisActive);

        if (document.querySelector('.ghost_move')) {
            document.querySelector('.ghost_move').after(thisActive);
            document.querySelector('.ghost_move').outerHTML = "";
        }
        if (thisActive) {
            thisActive.classList.remove('moving');
            thisActive.style.zIndex = null;
            thisActive.style.width = null;
            thisActive.style.left = null;
            thisActive.style.top = null;
            thisActive.style.position = null;
            thisActive = "";
        }

        document.removeEventListener("mousemove", moveStartItem, false);
        document.removeEventListener("touchmove", moveStartItem, false);
        document.removeEventListener('mouseup', moveStopItem);

        pageConts.classList.add('k2editableOrderChanged');

        isNeedSave();
    }

    function moveStartItem(event) {

        if ((typeof event.pageX !== "undefined")) {
            event.preventDefault();
            y = parseFloat(event.clientY - (thisActiveRect.height / 2));
        } else {
            y = parseFloat(event.touches[0].clientY - (thisActiveRect.height / 2));
        }

        //console.log(thisActiveRect);
        //console.log(x - thisActiveRect.left);

        if (document.querySelector('.ghost_move')) {
            document.querySelector('.ghost_move').outerHTML = "";
        }

        if (thisActive) {

            thisActive.style.zIndex = "-1";

            elementMove = document.elementFromPoint((widthWindow / 2), event.clientY - (thisActiveRect.height / 2));
            

            if (elementMove) {
                if ((elementMove.closest('.k2pageContainer') != null) && !elementMove.classList.contains('k2pageContainer')) {

                    var ghostElement = document.createElement('div');
                    ghostElement.classList.add('ghost_move');
                    ghostElement.style.height = thisActiveRect.height + 'px';

                    elementMove.insertAdjacentHTML('beforeBegin', ghostElement.outerHTML);


                } else {
                    var ghostElement = document.createElement('div');
                    ghostElement.classList.add('ghost_move');
                    ghostElement.style.height = thisActiveRect.height + 'px';

                    if (y < thisActive.parentNode.offsetTop) {
                        pageConts.insertAdjacentHTML('afterbegin', ghostElement.outerHTML);
                    } else {
                        pageConts.insertAdjacentHTML('beforeend', ghostElement.outerHTML);
                    }
                }
            }


            thisActive.style.top = y + "px";
            thisActive.style.zIndex = "1000";
            lastY = y;
        }
    }
}

//  funkce pro editaci odkazu
function editLink(target) {
    var editLink = document.querySelector('.editable_link'),
        isBlank,
        isBtn,
        href;
    if (target.hasAttribute("href")) {
        href = target.getAttribute('href');
        document.querySelector('#linkInputEdit').value = href;
    } else if (target.hasAttribute("data-selector")) {
        href = target.getAttribute('data-selector');
        document.querySelector('#linkInputEdit').value = href;
    }

    target.getAttribute('target') !== null ? isBlank = true : isBlank = false;
    target.classList.contains('btn') ? isBtn = true : isBtn = false;

    document.querySelector('#linkTitleEdit').value = target.getAttribute('title');
    
    if (isBlank) {
        editLink.querySelector('#linkNewCartEdit').checked = true;
    } else {
        editLink.querySelector('#linkNewCartEdit').checked = false;
    }
    if (isBtn) {
        editLink.querySelector('#linkNewButtonEdit').checked = true;
    } else {
        editLink.querySelector('#linkNewButtonEdit').checked = false;
    }
    floatElementToElement(editLink, target);
    elemLinkEdit = target;
}

//  funkce zmenu velikosti obrázku
function clickImageVideo(target) {

    selectElement(target);
    styleSelection();
    removeSelection();

    target.classList.add('active');
    var positionImg = target.getBoundingClientRect(),
        topImage = positionImg.top + window.pageYOffset,
        leftImage = positionImg.left,
        widthImage = positionImg.width,
        heightImage = positionImg.height,
        imageSet = document.querySelector('.image_set_edit');

    styleImage = target.currentStyle || window.getComputedStyle(target);
    imageFloat = styleImage.cssFloat;

    if (imageFloat === "right") {
        imageSet.querySelector('.point_move_edit').classList.add('reverse_edit');
        isreverse_edit = true;
    } else {
        imageSet.querySelector('.point_move_edit').classList.remove('reverse_edit');
        isreverse_edit = false;
    }

    imageSet.classList.add('active');
    imageSet.style.left = leftImage + 'px';
    imageSet.style.top = topImage + 'px';
    imageSet.style.width = widthImage + 'px';
    imageSet.style.height = heightImage + 'px';

    var marginBottom = target.style.marginBottom.replace("px", ""),
        marginTop = target.style.marginTop.replace("px", ""),
        marginLeft = target.style.marginLeft.replace("px", ""),
        marginRight = target.style.marginRight.replace("px", "");

    imageSet.querySelector('input[name="marginBottom"]').value = (marginBottom == "") ? 0 : marginBottom;
    imageSet.querySelector('input[name="marginTop"]').value = (marginTop == "") ? 0 : marginTop;
    imageSet.querySelector('input[name="marginLeft"]').value = (marginLeft.replace("px", "") == "") ? 0 : marginLeft;
    imageSet.querySelector('input[name="marginRight"]').value = (marginRight.replace("px", "") == "") ? 0 : marginRight;

    document.querySelector(".edit_layout").classList.remove("active");
}

function imageVideoSetResize(target) {
    var positionImg = target.getBoundingClientRect(),
        topImage = positionImg.top + window.pageYOffset,
        leftImage = positionImg.left,
        widthImage = positionImg.width,
        heightImage = positionImg.height,
        imageSet = document.querySelector('.image_set_edit');

    imageSet.style.left = leftImage + 'px';
    imageSet.style.top = topImage + 'px';
    imageSet.style.width = widthImage + 'px';
    imageSet.style.height = heightImage + 'px';
}

function resizeTable(tableEl) {
    const tableWrap = tableEl.closest(".table_wrapper");
    const BORDER_SIZE = 10;
    let m_pos;

    function resize(e) {
        const dx = m_pos - e.x;
        // helper => parent div::after of the var tableWrap
        const helper = tableWrap.closest(".table_helper_active");
        const MAX_WIDTH = helper.closest(".html_wrap").offsetWidth;
        let maxWidth;

        m_pos = e.x;

        if (tableWrap.closest(".table_helper_active"))
            maxWidth = tableWrap.closest(".table_helper_active").style.maxWidth;
        else
            maxWidth = tableWrap.style.maxWidth;


        if (maxWidth.charAt(maxWidth.length - 1) === "%")
            maxWidth = MAX_WIDTH;
        else
            maxWidth = maxWidth.slice(0, maxWidth.length - 2);

        if (maxWidth >= 250 && maxWidth <= MAX_WIDTH) {
            // Check if table is active
            if (tableWrap.closest(".table_helper_active")) {
                // maxWidth for helper
                const newVal = (parseInt(getComputedStyle(helper, '').width) - dx);
                helper.style.maxWidth = newVal + "px";
                tableWrap.style.maxWidth = "none";
            }

        } else {
            if ((maxWidth - 250) < (MAX_WIDTH - maxWidth)) {
                if (!tableWrap.closest(".table_helper_active"))
                    tableWrap.style.maxWidth = "250px";
                else
                    tableWrap.closest(".table_helper_active").style.maxWidth = "250px";
            } else {
                if (!tableWrap.closest(".table_helper_active"))
                    tableWrap.style.maxWidth = MAX_WIDTH + "px";
                else
                    tableWrap.closest(".table_helper_active").style.maxWidth = MAX_WIDTH + "px";
            }
        }
    }

    function mDown(e) {
        if ((tableWrap.offsetWidth - e.offsetX) < BORDER_SIZE && e.target == tableWrap.parentNode) {
            m_pos = e.x;
            document.addEventListener("mousemove", resize, false);
        } else if (e.target != tableWrap.parentNode) {
            if (e.target.closest(".table_helper_active") != tableWrap.closest(".table_helper_active")) {
                // Klik mimo tabulku
                tableWrap.removeAttribute('class');
                tableWrap.classList.add("table_wrapper");

                if (tableWrap.closest(".table_helper_active")) {
                    tableWrap.style.maxWidth = tableWrap.closest(".table_helper_active").style.maxWidth;
                    $(tableWrap).unwrap();
                }
                document.removeEventListener("mousedown", mDown, false);
            }
        }
    }

    // Obalení tabulky wrapem pro drag
    tableWrap.classList.add("table_resize_check");
    if ($(tableWrap).closest(".table_helper_active").length == 0) {
        $(tableWrap).wrap("<div class='table_helper_active'></div>");
        tableWrap.closest(".table_helper_active").style.maxWidth = tableWrap.style.maxWidth;
        tableWrap.style.maxWidth = "none";
    }

    // Listeners ---
    document.addEventListener("mousedown", mDown, false);
    document.addEventListener("mouseup", function (e) {
        document.removeEventListener("mousemove", resize, false);
    }, false);
    // \Listeners ---

}


