//            iframe = t.querySelector('iframe');
//            iframe.src = iframe.dataset.src;
            cookieInfo = t.querySelector('.cookie_info_text');

            if (cookieInfo) {
                cookieInfo.remove();
            }

        }); 
    });

    controler.addEventListener('mousedown', function (e) {
        e.preventDefault();
    });

    controler.querySelectorAll('input').forEach(function (el) {

        el.addEventListener('mousedown', function (e) {
            e.stopPropagation();
        })
    });

    document.querySelectorAll(".html_wrap").forEach(function (el) {
        if (el.hasAttribute("k2editortype")) {
            if (el.getAttribute("k2editortype") == "code") {
                toCodeEditor(el);
            } else if (el.getAttribute("k2editortype") == "visual") {

            } else el.setAttribute("k2editortype", "visual");

        } else el.setAttribute("k2editortype", "visual");
    });


    editableStart();

    /*pridani/odstraneni/velikost/pozice u obrazku a videa*/
    multimedia();

    layout();

    /*prace s odkazem*/
    linkSet();

    hashSet();

    // editace tabulky
    q('.btn_edit_table', 'click', function () {
        var type = this.getAttribute('data-type'),
            tdActive = elemTableTdEdit.element,
            colActive = elemTableTdEdit.activeX,
            rowActive = elemTableTdEdit.activeY,
            table = tdActive.closest('table'),
            lengthCol = elemTableTdEdit.lengthCol,
            lengthRow = elemTableTdEdit.lengthRow,
            tdGenerate = "";


        if (type === "removeTable") {
            selectElement(table);
            formatDoc('delete', false);
            restoreSelection();
        } else if (type === "addRow") {
            selectElement(table);
            for (i = 0; i < lengthCol; i++) {
                tdGenerate = tdGenerate + "<td></td>";
            }
            table.querySelectorAll('tr')[rowActive].insertAdjacentHTML('afterend', "<tr>" + tdGenerate + "</tr>");
            table = table.outerHTML;
            formatDoc('insertHtml', table);
        } else if (type === "removeRow") {
            selectElement(table);
            tdActive.parentElement.remove();
            table = table.outerHTML;
            formatDoc('insertHtml', table);
        } else if (type === "addCol") {
            var rowsTable = table.querySelectorAll('tr');
            for (i = 0; i < lengthRow; i++) {
                typeNode = rowsTable[i].firstChild.nodeName;
                createElement = document.createElement(typeNode);
                createElement = createElement.outerHTML;
                rowsTable[i].querySelectorAll(typeNode)[colActive].insertAdjacentHTML('afterend', createElement);
            }
            selectElement(table);
            table = table.outerHTML;
            formatDoc('insertHtml', table);
        } else if (type === "removeCol") {
            var rowsTable = table.querySelectorAll('tr');
            for (i = 0; i < lengthRow; i++) {
                typeNode = rowsTable[i].firstChild.nodeName;
                if (rowsTable[i].querySelectorAll(typeNode)[colActive]) {
                    rowsTable[i].querySelectorAll(typeNode)[colActive].remove();
                }
            }
            selectElement(table);
            table = table.outerHTML;
            formatDoc('insertHtml', table);
        } else if (type === "resizeTable") {
            resizeTable(table);

            selectElement(table);
            table = table.outerHTML;
            formatDoc('insertHtml', table);
        }
        restoreSelection();
        document.querySelector('.k2editableContent.active').click();
    });

    q('.btn_edit_layout', 'click', function () {
        var type = this.getAttribute("data-type");

        if (type == "removeLayout") {
            if (document.querySelector(".k2editableContent.active .layoutContent.active")) {
                document.querySelector(".k2editableContent.active .layoutContent.active").outerHTML = "";
                document.querySelector(".edit_layout").classList.remove("active");
                isNeedSave();
                document.querySelector(".k2editableContent.active").click();
            } else error("Není co vymazat");

        } else if (type == "addLayout") {
            if (document.querySelector(".k2editableContent.active .layoutContent.active")) {
                if (document.querySelector(".k2editableContent.active .layoutContent.active").hasAttribute("layout-id")) {
                    var layout = document.querySelector(".k2editableContent.active .layoutContent.active");
                    var id = layout.getAttribute("layout-id");
                    var content = document.querySelector('.layout_grid_edit .layoutContent[layout-id="' + id + '"]');

                    layout.outerHTML = layout.outerHTML + content.outerHTML + "<br>";
                    isNeedSave();
                } else error("Chybí údaje ke kopírování");
            } else error("Není co vymazat");
        } else if (type == "upLayout") {
            if (document.querySelector(".k2editableContent.active .layoutContent.active")) {
                var prev = document.querySelector(".k2editableContent.active .layoutContent.active").previousElementSibling;
                if (prev != null) {
                    var el = prev;
                    while ((el.lastElementChild != null) && !(el.classList.contains("layoutContent") || el.tagName.toLowerCase() == "table" || el.classList.contains("k2StyleEditor"))) {
                        el = el.lastElementChild;
                    }
                    el.before(document.querySelector(".k2editableContent.active .layoutContent.active"));
                } else {
                    var el = document.querySelector(".k2editableContent.active .layoutContent.active").parentElement.previousElementSibling,
                        elprev = document.querySelector(".k2editableContent.active .layoutContent.active").parentElement;
                    while (el == null) {
                        if (!elprev.classList.contains("k2editableContent")) {
                            el = elprev.parentElement.previousElementSibling;
                            elprev = elprev.parentElement;
                        } else el = elprev;

                    }
                    if (el.classList.contains("k2editableContent")) {
                        el = el.firstElementChild;
                    } else {
                        while ((el.lastElementChild != null) && !(el.classList.contains("layoutContent") || el.tagName.toLowerCase() == "table" || el.classList.contains("k2StyleEditor"))) {
                            el = el.lastElementChild;
                        }
                    }
                    if ((prev == null && elprev.classList.contains("k2editableContent"))) {
                        el = document.querySelector(".k2editableContent.active");
                        el.prepend(document.querySelector(".k2editableContent.active .layoutContent.active"));
                    } else {
                        el.before(document.querySelector(".k2editableContent.active .layoutContent.active"));
                    }


                }

                floatElementToElement(document.querySelector(".edit_layout"), document.querySelector(".k2editableContent.active .layoutContent .layout_item.active, .k2editableContent.active .layoutContent .contenteditable.active"));
                isNeedSave();
            } else error("Není co vymazat");
        } else if (type == "downLayout") {
            if (document.querySelector(".k2editableContent.active .layoutContent.active")) {
                var next = document.querySelector(".k2editableContent.active .layoutContent.active").nextElementSibling;
                if (next != null) {
                    var el = next;
                    while ((el.firstElementChild != null) && !(el.classList.contains("layoutContent") || el.tagName.toLowerCase() == "table" || el.classList.contains("k2StyleEditor"))) {
                        el = el.firstElementChild;
                    }
                    if (document.querySelector(".k2editableContent.active .layoutContent.active").nextSibling.nodeType == 3)
                        el.before(document.querySelector(".k2editableContent.active .layoutContent.active"));
                    else
                        el.after(document.querySelector(".k2editableContent.active .layoutContent.active"));
                } else {
                    var el = document.querySelector(".k2editableContent.active .layoutContent.active").parentElement.nextElementSibling,
                        elnext = document.querySelector(".k2editableContent.active .layoutContent.active").parentElement;
                    while (el == null) {
                        if (!elnext.classList.contains("k2editableContent")) {
                            el = elnext.parentElement.nextElementSibling;
                            elnext = elnext.parentElement;
                        } else el = elnext;

                    }
                    if (el.classList.contains("k2editableContent")) {
                        el = el.lastElementChild;
                    } else {
                        while ((el.firstElementChild != null) && !(el.classList.contains("layoutContent") || el.tagName.toLowerCase() == "table" || el.classList.contains("k2StyleEditor"))) {
                            el = el.firstElementChild;
                        }
                    }
                    if ((next == null && elnext.classList.contains("k2editableContent"))) {
                        el = document.querySelector(".k2editableContent.active");
                        el.append(document.querySelector(".k2editableContent.active .layoutContent.active"));
                    } else {
                        el.after(document.querySelector(".k2editableContent.active .layoutContent.active"));
                    }


                }
                floatElementToElement(document.querySelector(".edit_layout"), document.querySelector(".k2editableContent.active .layoutContent .layout_item.active, .k2editableContent.active .layoutContent .contenteditable.active"));
                isNeedSave();
            } else error("Není co vymazat");
        }
    });


    // zmena stylu a pozice bloku na strance
    moveWebContent();


    if(!window.webK2){
        //trigger saving 
        saving(); 
    } else { 
        document.body.classList.add('webK2');
        window.addEventListener('resize', changeMarginToolbar);
        document.addEventListener('click', function (e) {
            var elementClick1 = isElement(e, 'codeEditor_button');
            var elementClick2 = isElement(e, 'visualEditor_button');
            if(elementClick1 || elementClick2){
                changeMarginToolbar();
            } 
        });
        
        changeMarginToolbar();
        function changeMarginToolbar(){
            let margin = document.querySelector('.editable_control').offsetHeight;
            if(!window.webK2){
                margin+= 30;
            } else {
                margin+= 10;
            }
            document.querySelector('.k2editableContent').setAttribute('style', 'margin-top:'+ margin +'px !important');
        }
    }
}

document.addEventListener("DOMContentLoaded", function (event) {
    var isChrome = /Chrome/.test(navigator.userAgent) && /Google Inc/.test(navigator.vendor);
    var isMozilla = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;


    if (editingInK2) {
        document.body.classList.add('editingInK2');
        /*document.querySelectorAll('a, button, input').forEach(function (t) {

            console.log(!!t.closest('.template_edit_container'));
            console.log(!!t.closest('.k2editableHtml'));
            console.log(t);
            if (!!t.closest('.template_edit_container')) {
                t.addEventListener('click', function (e) {
                    console.log(!!this.closest('.k2editableHtml'));
                    console.log(!startEditingInK2);
                    console.log(this.nodeName);
                    if(this.nodeName == "A"){
                    }
                        e.preventDefault();
                    if(!!this.closest('.k2editableHtml') && !startEditingInK2){
                        e.stopPropagation();
                    }

                });
            }
        });*/
    }

    //console.log(isChrome || isMozilla && !editingInK2)
    if ((isChrome || isMozilla) && !editingInK2) {
        startEditing();
    } else {
        if (!editingInK2) {
            document.querySelector('.editable_main_set').outerHTML = "";
            var items = document.querySelectorAll('.k2editableContent');
            itemsLength = items.length;
            for (i = 0; i < itemsLength; i++) {
                items[i].classList.remove('k2editableContent')
            }
        } else {
            document.addEventListener('changeEditMode', function (e) {
                if (e.editMode) {
                    document.body.classList.add('edit_in_k2_start')
                    //document.querySelector('.container_edit_for_k2').classList.add('not_visible')
                    //document.querySelector('.k2editableContent').classList.remove('notEditable')
                    //document.querySelector('.editable_main_set').classList.remove('not_visible');
                    var items = document.querySelectorAll('.k2editableContent');
                    itemsLength = items.length;
                    for (i = 0; i < itemsLength; i++) { 
                        //log.value = e.firstLoadData;
                        if (e.firstLoadData) {
                            fieldName = checkVariable(items[i].getAttribute('data-k2-segitor'));
                            items[i].setAttribute('data-k2-field', fieldName);
                        }
                        items[i].classList.remove('notEditable');
                        items[i].contentEditable = true;
                    }
                    if (!startEditingInK2) { 
                        startEditing(); 
                    }
                    startEditingInK2 = true;
                } else {
                    document.body.classList.remove('edit_in_k2_start') 
                    document.dispatchEvent(new Event('mousedown'));
                    var items = document.querySelectorAll('.k2editableContent');
                    itemsLength = items.length;
                    for (i = 0; i < itemsLength; i++) {
                        if (e.firstLoadData) { 
                            fieldName = checkVariable(items[i].getAttribute('data-k2-segitor'));
                            items[i].setAttribute('data-k2-field', fieldName);
                        }
                        items[i].classList.add('notEditable');
                        items[i].contentEditable = false;
                    }
                    //startEditingInK2 = false;
                }
            })

        }

    }
});

function layout() {
    var container = document.querySelector('.layout_grid_edit');
    if (!(typeof editableLayoutsData === 'undefined')) {
        editableLayoutsData.forEach(importLayouts);
        console.log(editableLayoutsData);
    }
    if (!(typeof specialEditableLayoutsData === 'undefined')) {
        specialEditableLayoutsData.forEach(importLayouts);
    }

    function importLayouts(layout) { // Přelouská a vepíše layouty do popupu
        var content = "";
        var afterHtml = "";
        var btnClass = "";

        if (!layout.html) {
            layout.items.forEach(function (item, n) {
                content = content + '<div class="layout_item k2StyleEditor ' + item.class + '" data-n="' + n + '" contenteditable="false"><br></div>';

            });
        } else {
            var dom = new DOMParser().parseFromString(layout.html, 'text/html').body.firstElementChild;
            dom.querySelectorAll("[class]").forEach(function (el) {
                el.classList.add("k2StyleEditor");
            });
            if (dom.hasAttribute("class")) dom.classList.add("k2StyleEditor");
            content = dom.outerHTML;
            afterHtml = "<div class=' html_text'><div class='box'><div>HTML</div></div></div>";
            btnClass = "html";
        }

        if (container) {
            var itemHtml = '<div class="layout_item_edit "><button title="' + layout.description + '" class="layout_button ' + btnClass + '"><h3>' + layout.title + '</h3><div class="layoutContent k2StyleEditor ' + layout.mainClass + '" layout-id="' + layout.mainClass + '">' + content + '</div>' + afterHtml + '</button></div>'
            container.innerHTML = container.innerHTML + itemHtml;
        }
    }

    var buttons = document.querySelectorAll(".layout_button"); //Posluchač pro klik
    if (buttons) {
        buttons.forEach(function (el) {
            el.addEventListener("click", function (e) {
                clickLayout(e, el)
            });
        });
    }

    function clickLayout(e, item) { //Při vybrání layoutu k vložení do editoru
        e.preventDefault();
        if(!document.querySelector('.k2editableContent.active')) return;
        var content = item.querySelector(".layoutContent");
        var isVisual = (document.querySelector('.k2editableContent.active').getAttribute("k2editortype") == "visual") ? true : false;
        if (isVisual) {
            var popup = document.querySelector('.popup_edit_container.active');
            if (document.querySelector('.controler_btn.active')) {
                document.querySelector('.controler_btn.active').click();
            }
            if (popup) {
                popup.querySelector('.btn_pop').click();
            }

            var sel = window.getSelection && window.getSelection();
            //Pokud se kurzor nachází v layoutu, přesune ho na konec k2editoru a zneaktivní layouty
            if (sel && sel.rangeCount > 0) {
                var el = sel.getRangeAt(0).commonAncestorContainer;
                if (!(el && el.nodeType === Node.ELEMENT_NODE)) el = window.getSelection().getRangeAt(0).commonAncestorContainer.parentNode;
                if (el.closest(".layoutContent")) {
                    el.closest(".layoutContent").outerHTML = el.closest(".layoutContent").outerHTML + content.outerHTML + "<br>";
                } else {
                    formatDoc('insertHTML', content.outerHTML + "<br>");
                }
            } else {
                document.querySelector('.k2editableContent.active').innerHTML = document.querySelector('.k2editableContent.active').innerHTML + content.outerHTML + "<br>";
            }


            isNeedSave();
        }
    }


}

function setEndOfContenteditable(contentEditableElement) {
    var range, selection;
    if (document.createRange) //Firefox, Chrome, Opera, Safari, IE 9+
    {
        range = document.createRange(); //Create a range (a range is a like the selection but invisible)
        range.selectNodeContents(contentEditableElement); //Select the entire contents of the element with the range
        range.collapse(false); //collapse the range to the end point. false means collapse to end rather than the start
        selection = window.getSelection(); //get the selection object (allows you to change selection)
        selection.removeAllRanges(); //remove any selections already made
        selection.addRange(range); //make the range you have just created the visible selection
    } else if (document.selection) //IE 8 and lower
    {
        range = document.body.createTextRange(); //Create a range (a range is a like the selection but invisible)
        range.moveToElementText(contentEditableElement); //Select the entire contents of the element with the range
        range.collapse(false); //collapse the range to the end point. false means collapse to end rather than the start
        range.select(); //Select the range (make it the visible selection
    }
}


function multimedia() {
    // přidaní videa
    q('.btn_video', 'click', function () {
        var videoUrl = document.querySelector('#videoLink').value,
            urlDecode = videoUrl.match(/(http:|https:|)\/\/(player.|www.)?(vimeo\.com|youtu(be\.com|\.be|be\.com))\/(video\/|embed\/|watch\?v=|v\/)?([A-Za-z0-9._%-]*)(\&\S+)?/),
            urlHash,
            web;

        if (urlDecode !== null) {
            urlHash = urlDecode[6];
            web = urlDecode[3];


            if ((web == "youtube.com") || (web == "youtu.be")) {
                var videoHtml =
                    '<div class="k2StyleEditor editable_video_content_cookies video_rect youtube_load" data-hash="' + videoUrl + '" data-img="" style="background: url(\'https://img.youtube.com/vi/' + urlHash + '/hqdefault.jpg\')">' +
                    '<span></span>' +
                    '</div>';


                restoreSelection();
                getSelectionParentElement().innerHTML = videoHtml;


                //formatDoc('insertHtml', videoHtml);

            } else if (web == "vimeo.com") {
                var videoHtml = 
                '<div class="k2StyleEditor editable_video_content_cookies video_rect youtube_load" data-hash="' + videoUrl + '" data-img="">' +
                '<span></span>' +
                '</div>';
                
                restoreSelection();
                getSelectionParentElement().innerHTML = videoHtml;


            } else {
                error("Chybně vyplněná URL pro vložení videa");
            }
        } else {
            error("Chybně vyplněná URL pro vložení videa");
        }

        if (document.querySelector('.controler_btn.active')) {
            document.querySelector('.controler_btn.active').click();
        }

    });

    // změna velikosti obrázku a videa
    q('.btn_media_resize', 'click', function () {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');

        if (elementImg) {
            restoreSelection();
            var value = this.getAttribute('data-value');
            elementImg.style.width = value + '%';
            elementImg.style.height = 'auto';
            elementImg.click();
        }
    });

    // změna velikosti obrázku a videa
    q('.btn_media_remove', 'click', function () {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');

        /*selectElement(elementImg);
        formatDoc('delete', null);*/
        elementImg.outerHTML = "";
        /*saveSelection();*/
        if (document.querySelector('.image_set_edit.active')) {
            document.querySelector('.image_set_edit').classList.remove('active');
        }
        restoreSelection();
    });

    // změna margin hodnoty
    q('input[name="marginTop"]', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');
        if (e.target.value > 999) {
            e.target.value = 999;
        }
        elementImg.style.marginTop = e.target.value + "px";
        imageVideoSetResize(elementImg);
        isNeedSave(document.querySelector(".k2editableContent.active"));
    });
    q('input[name="marginBottom"]', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');
        if (e.target.value > 999) {
            e.target.value = 999;
        }
        elementImg.style.marginBottom = e.target.value + "px";
        imageVideoSetResize(elementImg);
        isNeedSave(document.querySelector(".k2editableContent.active"));
    });
    q('input[name="marginLeft"]', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');
        if (e.target.value > 999) {
            e.target.value = 999;
        }
        elementImg.style.marginLeft = e.target.value + "px";
        imageVideoSetResize(elementImg);
        isNeedSave(document.querySelector(".k2editableContent.active"));
    });
    q('input[name="marginRight"]', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');
        if (e.target.value > 999) {
            e.target.value = 999;
        }
        elementImg.style.marginRight = e.target.value + "px";
        imageVideoSetResize(elementImg);
        isNeedSave(document.querySelector(".k2editableContent.active"));
    });

    // změna padding hodnoty layoutu
    q('.edit_layout input', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent.active .layoutContent.active .layout_item.active, .k2editableContent.active .layoutContent.active .contenteditable.active')

        if (this.getAttribute("name") == "paddingLeft") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingLeft = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingTop") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingTop = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingRight") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingRight = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingBottom") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingBottom = e.target.value + "px";
        }

        isNeedSave(document.querySelector(".k2editableContent.active"));
    });


    // změna padding hodnoty layoutu
    q('.edit_layout input', 'input', function (e) {
        var elementImg = document.querySelector('.k2editableContent.active .layoutContent.active .layout_item.active, .k2editableContent.active .layoutContent.active .contenteditable.active')

        if (this.getAttribute("name") == "paddingLeft") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingLeft = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingTop") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingTop = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingRight") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingRight = e.target.value + "px";
        }
        if (this.getAttribute("name") == "paddingBottom") {
            if (e.target.value > 999) {
                e.target.value = 999;
            }
            elementImg.style.paddingBottom = e.target.value + "px";
        }

        isNeedSave(document.querySelector(".k2editableContent.active"));
    });


    // obtékání textu obrázku a videa
    q('.btn_media_float_edit', 'click', function () {
        var floatTyp = this.getAttribute('data-float'),
            imgActive = document.querySelector('.k2editableContent.active img.active') || document.querySelector('.k2editableContent.active .editable_video_content.active'),
            parentImg = imgActive.parentNode,
            imgClone = imgActive;

        if (!parentImg.classList.contains('k2editableContent')) {
            parentImg.style.overflow = "hidden";
        }

        //EDIT:: parent overflow: hidden všechno?

        imgClone.style.float = floatTyp;

        if (floatTyp === "none") {
            imgClone.style.marginLeft = '0px';
            imgClone.style.marginRight = '0px';
            imgClone.style.marginTop = '0px';
            imgClone.style.marginBottom = '0px';
            imgClone.style.position = 'relative';
            imgClone.style.zIndex = null;
        } else if (floatTyp === "left") {
            imgClone.style.marginLeft = '0px';
            imgClone.style.marginRight = '20px';
            imgClone.style.marginTop = '20px';
            imgClone.style.marginBottom = '20px';
            imgClone.style.position = 'relative';
            imgClone.style.zIndex = '1';
        } else if (floatTyp === "right") {
            imgClone.style.marginLeft = '20px';
            imgClone.style.marginRight = '0px';
            imgClone.style.marginTop = '20px';
            imgClone.style.marginBottom = '20px';
            imgClone.style.position = 'relative';
            imgClone.style.zIndex = '1';
        } else if (floatTyp === "center") {
            imgClone.style.margin = '0 auto';
            imgClone.style.float = '';
            imgClone.style.display = 'block';
            imgClone.style.position = 'relative';
            imgClone.style.zIndex = '1';
        }

        /*   selectElement(imgActive);
           formatDoc('delete', null);

           if (imgActive) {
               imgActive.outerHTML = "";
           }
           saveSelection();
           formatDoc('insertHtml', imgClone.outerHTML);
           restoreSelection();*/
        /*document.querySelector('.k2editableContent.active').click();*/

        if (document.querySelector('.image_set_edit.active')) {
            document.querySelector('.image_set_edit').classList.remove('active');
        }
    });

    // zmena velikosti obrázku a videa
    imageVideoResize();

}

function linkSet() {

    // mazaní odkazu z editované části
    q('.btn_link_remove', 'click', function () {
        if (elemLinkEdit) {
            selectElement(elemLinkEdit);
            saveSelection();
            restoreSelection();
            formatDoc('insertHTML', '<span>' + elemLinkEdit.innerText + '</span>');
            restoreSelection();
            if (document.querySelector('.editable_link.active')) {
                document.querySelector('.editable_link.active').classList.remove('active');
            }
        }
    });

    // editace odkazu z editované části
    q('.btn_link_edit', 'click', function () {
        console.log(elemLinkEdit)
        if (elemLinkEdit) {
            selectElement(elemLinkEdit);
            saveSelection();
            restoreSelection();
            var sLnk = document.querySelector('#linkInputEdit').value,
                linkTitle = document.querySelector('#linkTitleEdit').value,
                newCart = document.querySelector('#linkNewCartEdit').checked,
                createButton = document.querySelector('#linkNewButtonEdit').checked,
                sText = document.getSelection(),
                imgInLink = elemLinkEdit.querySelector('img'),
                expression1 = /((?:https?\:\/\/|www\.)(?:[-a-z0-9]+\.)*[-a-z0-9]+.*)/i,
                regex1 = new RegExp(expression1),
                expression2 = /^\/([^?\/]+)/i,
                regex2 = new RegExp(expression2);
            expression3 = /(?![.*])#\S+/i,
                regex3 = new RegExp(expression3);

            if (sLnk.match(regex1) || sLnk.match(regex2)) {
                classButton = createButton ? 'class="btn btn_normal k2StyleEditor"' : '';
                console.log(elemLinkEdit);
                if (imgInLink) {
                    htmlImg = imgInLink.outerHTML;
                    elemLinkEdit.remove();
                    if (newCart) {
                        formatDoc('insertHTML', '<a href="' + sLnk + '" title="' + linkTitle + '" target="_blank">' + htmlImg + '</a>');
                    } else {
                        formatDoc('insertHTML', '<a href="' + sLnk + '" title="' + linkTitle + '">' + htmlImg + '</a>');
                    }
                } else if (quantitySelection()) {
                    if (newCart) {
                        formatDoc('insertHTML', '<a href="' + sLnk + '" ' + classButton + ' title="' + linkTitle + '" target="_blank">' + sText + '</a>');
                    } else {
                        formatDoc('insertHTML', '<a href="' + sLnk + '" ' + classButton + '" title="' + linkTitle + '">' + sText + '</a>');
                    }
                } else {
                    error("Vyberte prosím text");
                }
                if (document.querySelector('.editable_link.active')) {
                    document.querySelector('.editable_link.active').classList.remove('active');
                }
            } else if (sLnk.match(regex3)) {
                classButton = createButton ? 'class="btn btn_normal js_favorite k2StyleEditor"' : 'class="js_favorite k2StyleEditor"';
                if (imgInLink) {
                    htmlImg = imgInLink.outerHTML;
                    elemLinkEdit.remove();
                    if (newCart) {
                        formatDoc('insertHTML', '<a data-selector="' + sLnk + '" href="' + sLnk + '" title="' + linkTitle + '" class="js_favorite k2StyleEditor" target="_blank">' + htmlImg + '</a>');
                    } else {
                        formatDoc('insertHTML', '<a data-selector="' + sLnk + '" href="' + sLnk + '" title="' + linkTitle + '" class="js_favorite k2StyleEditor">' + htmlImg + '</a>');
                    }
                } else if (quantitySelection()) {
                    if (newCart) {
                        formatDoc('insertHTML', '<a data-selector="' + sLnk + '" href="' + sLnk + '" title="' + linkTitle + '" ' + classButton + ' target="_blank">' + sText + '</a>');
                    } else {
                        formatDoc('insertHTML', '<a data-selector="' + sLnk + '" href="' + sLnk + '" title="' + linkTitle + '" ' + classButton + '">' + sText + '</a>');
                    }
                } else {
                    error("Vyberte prosím text");
                }
                if (document.querySelector('.editable_link.active')) {
                    document.querySelector('.editable_link.active').classList.remove('active');
                }
            } else {
                error("Chybně vyplněná URL");
            }
            restoreSelection();
        }


    });

}


function hashSet() {

    // mazaní kotvy z editované části
    q('.btn_hash_remove', 'click', function () {
        console.log('click');
        var id = document.querySelector('.hash_setting.active').parentElement.getAttribute('id');
        document.querySelector('#' + id).outerHTML = "";
        if (document.querySelector('.editable_hash.active')) {
            document.querySelector('.editable_hash.active').classList.remove('active');
        }
        isNeedSave(document.querySelector('.k2editableContent.active'));
    });

    // editace kotvy z editované části
    q('.btn_hash_edit', 'click', function () {
        var id = document.querySelector('#HashNameEdit').value;
        var activeHashEl = document.querySelector('.hash_setting.active').parentElement;
        var linkHashUrl = document.querySelector('#linkHash')

        activeHashEl.setAttribute('id', id);
        linkHashUrl.value = location.href.split('?')[0].split('#')[0] + "#" + id;
    });

}


function moveWebContent() {

    // zmena stylu pozice bloku na stránce
    q('.editable_change_view ', 'click', function () {
        this.classList.toggle('active');
        pageConts.classList.toggle('no_view');
    });

    // zmena pozice bloku na stránce
    q('.editable_change', 'click', function () {
        var items = document.querySelectorAll('.k2pageContainer > *'),
            itemsLength = items.length;

        document.querySelector('html').classList.toggle('disable_editor');
        this.classList.toggle('active');
        isChangeMove = this.classList.contains('active');

        if (isChangeMove) {

            for (i = 0; i < itemsLength; i++) {
                var height = items[i].offsetHeight;
                items[i].style.height = (height / 2) + "px";
            }


        } else {

            for (i = 0; i < itemsLength; i++) {
                items[i].style.height = null;
            }

        }

        pageConts.classList.toggle('change_item_active_edit');
        document.querySelector('.editable_change_view').classList.toggle('view_active');


    });

    // přesouvaní sekcí
    moveContent();


}

function editableStart() {
    if (pageConts === null) {
        document.querySelector('.editable_change').style.display = "none";
    }


    // zneaktivnení editované časti a controleru při kliknutí mimo ně
    document.addEventListener('mousedown', function (event) {
        var t = (event.target.nodeType == 9 ? document.body : event.target);
        isCl = true;
        isImgResize = true;
        isVideoResize = true;
        isEditLink = true;
        isEditTable = true;
        isEditLayout = true;
        isAddImg = true;
        isDateTime = true;
        isHashSetting = true;


        while (true) {

            if (t.classList.contains('k2editableContent') && t.classList.contains('active') || t.classList.contains('editable_control')) {
                isCl = false;
                if (t.classList.contains('k2editableDatetime')) {
                    isDateTime = false;
                }
                break;
            }
            if (t.classList.contains('editable_link')) {
                isEditLink = false;
                isCl = false;
                break;
            }

            if (t.classList.contains('edit_table')) {
                isEditTable = false;
                isCl = false;
                break;
            }
            if (t.classList.contains('edit_layout')) {
                isEditLayout = false;
                isCl = false;
                break;
            }
            if (t.classList.contains('edit_layout')) {
                isEditLayout = false;
                isCl = false;
                break;
            }

            if (t.classList.contains('editable_hash')) {
                isHashSetting = false;
                isCl = false;
                break;
            }

            if (t.classList.contains('btn_pop')) {
                isAddImg = false;
                isCl = false;
                break;
            }

            if (t.classList.contains('editable_datetime')) {
                isCl = false;
                isDateTime = false;
                break;
            }


            if ((t.classList.contains('image_set_edit')) || (t.classList.contains('editable_video_content')) || (t.classList.contains('controler_btn')) || (t.classList.contains('editable_btn') || (t.classList.contains('layout_button')))) {
                isCl = false;
                isImgResize = false;
                break;
            }

            if (t.parentElement == null) {
                break;
            }

            t = t.parentElement;

        }
        //

        if (isDateTime) {

            if (document.querySelector('.editable_datetime.active')) {
                document.querySelector('.editable_datetime.active').classList.remove('active');
            }

        }


        if (isCl) {
            if (document.querySelector('.k2editableContent.active')) {
                document.querySelector('.k2editableContent.active').classList.remove('active');
            }
            if (document.querySelector('.editable_control.active')) {
                document.querySelector('.editable_control.active').classList.remove('active');
                document.querySelector('#visibleHash').click();
            }
            allowedEditable = true;

        }

        if (isEditLink) {
            if (document.querySelector('.editable_link.active')) {
                document.querySelector('.editable_link.active').classList.remove('active');
            }
        }

        if (isImgResize) {
            if (document.querySelector('.k2editableContent img.active')) {
                document.querySelector('.k2editableContent img.active').removeAttribute('class');
            }

            if (document.querySelector('.k2editableContent .editable_video_content.active')) {
                document.querySelector('.k2editableContent .editable_video_content.active').classList.remove('active');
            }


            if (document.querySelector('.image_set_edit.active')) {
                document.querySelector('.image_set_edit').classList.remove('active');
            }
        }

        if (isEditTable) {
            if (document.querySelector('.edit_table.active')) {
                document.querySelector('.edit_table.active').classList.remove('active');
            }
        }
        if (isEditLayout) {
            if (document.querySelector(".edit_layout.active")) {
                document.querySelector(".edit_layout.active").classList.remove("active");
            }
        }
        if (isEditLayout) {
            if (document.querySelector(".edit_layout.active")) {
                document.querySelector(".edit_layout.active").classList.remove("active");
            }
        }


    }, false);

    q('.k2editableContent', "paste", function (e) {
        if ((!this.classList.contains('k2editableHtml')) && (!this.classList.contains('k2editableDatetime'))) {
            var maxLength = this.getAttribute('data-k2-max');

            saveSelection();
            e.preventDefault();
            var selectionObject = window.getSelection();
            var contentText = this.textContent;
            var sectionStart = selectionObject.anchorOffset;
            var sectionEnd = selectionObject.extentOffset;
            var pasteText = (e.originalEvent || e).clipboardData.getData('text/plain').replace(/(\r\n|\n|\r)/gm, "");
            console.log(pasteText);

            if (sectionStart > sectionEnd) {
                tempSection = sectionStart;
                sectionStart = sectionEnd;
                sectionEnd = tempSection;
            }

            var splitContentText = contentText.split('');
            if (sectionStart != sectionEnd) {
                splitContentText.splice(sectionStart, sectionEnd - sectionStart);
            }

            splitContentText.splice(sectionStart, 0, pasteText);
            contentText = splitContentText.join('');
            contentTextLength = contentText.length;


            if (!((maxLength > 0) && (contentTextLength <= maxLength))) {
                contentText = contentText.substring(0, maxLength);
                formatDoc("selectAll", true);
                formatDoc("delete", true);
                formatDoc("insertText", contentText);
                setCaretOnlyText(this, maxLength);
                error("Editovaný text je přílíš dlouhý");
            } else {
                restoreSelection();
                console.log(pasteText);
                formatDoc("insertText", pasteText);
            }

        } else if (this.classList.contains('k2editableHtml')) {
            e.preventDefault();
            var pasteText = (e.originalEvent || e).clipboardData.getData('text/plain');
            var pasteHtml = (e.originalEvent || e).clipboardData.getData('text/html');

            if (pasteHtml != "") {
                var el = document.createElement('html');
                el.innerHTML = pasteHtml;
                el.querySelectorAll('body *').forEach(function (item) {
                    var attributes = item.attributes;

                    attributes = Array.prototype.slice.call(attributes);

                    attributes.forEach(function (attr) {
                        var element = attr;
                        if (typeof element == 'object') {
                            nameAttribute = element.name;
                            acceptAttribute = ['size', 'color', 'href', 'target'];
                            if (acceptAttribute.indexOf(nameAttribute) == -1) {
                                item.removeAttribute(nameAttribute);
                            }
                        }
                    });

                    var nameNode = item.nodeName,
                        textContent = item.textContent.trim(),
                        acceptNode = ['font', 'p', 'a', 'br', 'hr', 'ol', 'ul', 'li', 'strong', 'em', 'b', 'u', 'i', 'blockquote', 'div', 'span', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'pre', 'sup', 'sub', 'div', 'strike', 'table', 'th', 'tr', 'td', 'img', 'iframe'];


                    if (acceptNode.indexOf(nameNode.toLowerCase()) == -1) {

                        if (!textContent == "") {
                            item.insertAdjacentHTML('afterend', '<div>' + textContent + '</div>');
                        }
                        item.outerHTML = "";

                    } else {
                        if ((textContent == "") && (nameNode != 'IMG')) {
                            item.outerHTML = "";
                        }
                    }
                });

                stringHtml = el.querySelector('body').innerHTML.toString();
                stringHtml = stringHtml.replace(/<\!--.*?-->/g, "");

                if (stringHtml != pasteHtml) {
                    error("Při vkládání byl obsah pozměněn");
                }

                formatDoc("insertHtml", stringHtml);
            } else {
                formatDoc("insertText", pasteText);
            }
        }
    });

    window.addEventListener("resize", function () {
        if (typeof clickHistory !== "undefined" && controler.classList.contains("active")) {
            if (allowedEditable) {
                if (document.querySelector('.k2editableContent.active')) {
                    document.querySelector('.k2editableContent.active').classList.remove('active');
                }

                if (clickHistory.classList.contains('k2editableHtml')) {
                    console.log(document.getSelection().anchorNode)
                    if (document.getSelection().anchorNode.tagName) {
                        if (document.getSelection().anchorNode.tagName.toLowerCase() == "img") {
                            var el = document.getSelection().anchorNode;
                            var range = document.createRange();
                            var sel = window.getSelection();
                            range.setStartAfter(el);
                            range.collapse(true);
                            sel.removeAllRanges();
                            sel.addRange(range);

                        }
                    }

                    controler.classList.add('active');
                    var editablePosition = clickHistory.getBoundingClientRect(),
                        widthEditable = editablePosition.width + 8,
                        itemsImage = "",
                        imageEditable = clickHistory.getAttribute('k2editableimages');

                    var editorType = clickHistory.getAttribute("k2editortype");
                    if (editorType == "code") {
                        controler.querySelector(".codeEditor_button").classList.add("active");
                        controler.querySelector(".visualEditor_button").classList.remove("active");
                    } else if (editorType == "visual") {
                        controler.querySelector(".codeEditor_button").classList.remove("active");
                        controler.querySelector(".visualEditor_button").classList.add("active");
                    }

                    if (imageEditable) {
                        imageEditable = imageEditable.split('|');
                        for (i = 0; i < imageEditable.length; i++) {
                            itemsImage += '<div class="gallery_item_edit"><button title="Obrázek" class="editable_btn" data-elem="#images_pop" data-type="insertimage" data-value="' + imageEditable[i] + '?w=1920"><img src="' + imageEditable[i] + '"></button></div>'
                        }
                    } else {
                        itemsImage = "<h2>Nebyl nalezen žádný obrázek</h2>"
                    }

                    document.querySelector('.gallery_grid_edit').innerHTML = itemsImage;

                    controler.style.width = widthEditable + "px";

                    if (widthEditable <= 600 && document.querySelector("main")) {
                        var wrap = (clickHistory.closest(".wrap")) ? clickHistory.closest(".wrap") : document.querySelector("main");
                        var computedStyle = getComputedStyle(wrap);
                        controler.style.width = ((wrap.clientWidth || document.querySelector("main").clientWidth) - parseFloat(computedStyle.paddingLeft) - parseFloat(computedStyle.paddingRight)) + "px";
                    }

                    var controlerHeight = controler.offsetHeight,
                        topEditable = editablePosition.top + window.pageYOffset - controlerHeight - 3,
                        leftEditable = editablePosition.left - 4;

                    controler.style.left = leftEditable + "px";
                    controler.style.top = topEditable + "px";
                    controler.style.width = widthEditable + "px";
                    controler.style.position = "absolute";

                    var isCodeEditor = document.querySelector(".codeEditor_button").classList.contains("active");

                    if (widthEditable <= 600 && document.querySelector("main") && !isCodeEditor) {
                        let padding = parseFloat(computedStyle.paddingLeft);
                        let mainLeft = (wrap.getBoundingClientRect().left) + padding;
                        let fieldLeft = document.querySelector(".k2editableContent.k2editableHtml").getBoundingClientRect().left;
                        let posX = fieldLeft - mainLeft - 7;
                        let tolerance = 5;
                        controler.style.width = ((wrap.clientWidth) - padding - parseFloat(computedStyle.paddingRight)) - tolerance + "px";
                        controler.style.left = controler.getBoundingClientRect().left - posX + "px";
                        controlerHeight = controler.offsetHeight;
                        topEditable = editablePosition.top + window.pageYOffset - controlerHeight - 3;
                        controler.style.top = topEditable + "px";

                    }

                    controler.querySelector(".editable_editorSwitch_wrap").classList.remove("bottom");


                    triggerRange();
                } else {
                    controler.classList.remove('active');
                }


                if (clickHistory.hasAttribute("k2editortype")) {
                    if (!(clickHistory.getAttribute("k2editortype") == "code")) {
                        if (clickEHistory.target.closest(".layoutContent")) {
                            if (!clickEHistory.target.closest(".layoutContent").classList.contains("active")) {

                                clickEHistory.target.closest(".layoutContent").querySelectorAll(".layout_item, .contenteditable").forEach(function (item) {
                                    item.setAttribute("contenteditable", "true");
                                });
                                document.querySelectorAll(".layoutContent.active").forEach(function (item) {
                                    item.classList.remove("active");
                                });
                                clickEHistory.target.closest(".layoutContent").classList.add("active");
                                clickEHistory.target.closest(".layoutContent").removeAttribute("contenteditable");

                                clickHistory.removeAttribute("contenteditable");

                                clickEHistory.target.focus();
                            }
                            var layoutItem = e.target.closest(".layout_item, .contenteditable");
                            var layoutEdit = document.querySelector(".edit_layout");

                            document.querySelectorAll(".layout_item.active, .contenteditable.active").forEach(function (item) {
                                item.classList.remove("active")
                            });

                            if (layoutItem) {
                                layoutItem.classList.add("active");
                                layoutEdit.querySelector('input[name="paddingTop"]').value = layoutItem.style.paddingTop.replace("px", "") || 0;
                                layoutEdit.querySelector('input[name="paddingBottom"]').value = layoutItem.style.paddingBottom.replace("px", "") || 0;
                                layoutEdit.querySelector('input[name="paddingLeft"]').value = layoutItem.style.paddingLeft.replace("px", "") || 0;
                                layoutEdit.querySelector('input[name="paddingRight"]').value = layoutItem.style.paddingRight.replace("px", "") || 0;

                                if (!document.querySelector(".k2editableContent.active img.active"))
                                    floatElementToElement(layoutEdit, layoutItem);
                            }


                        } else {
                            if (clickHistory.querySelector(".layoutContent")) {
                                clickHistory.querySelectorAll(".layout_item, .contenteditable").forEach(function (item) {
                                    item.removeAttribute("contenteditable");
                                    item.classList.remove("active");
                                });
                                this.querySelectorAll(".layoutContent").forEach(function (item) {
                                    item.classList.remove("active");
                                    item.setAttribute("contenteditable", "false");
                                });
                                document.querySelector(".edit_layout").classList.remove("active");
                            }

                            clickHistory.setAttribute("contenteditable", "true");
                            clickHistory.focus();
                        }

                    }
                } else {
                    clickHistory.setAttribute("contenteditable", "true");
                    clickHistory.focus();
                }

                clickHistory.classList.add('active');

                document.dispatchEvent(new Event('scroll'));
                existHash();
                styleSelection();
                saveSelection();

            }
        }
    })

    // zaktivnení editované časti a pokud se jedná o html obsah tak spuštení controleru contentEditableStart
    q('.k2editableContent:not(.k2editableDatetime)', 'click', function (e) {
        clickHistory = this;
        clickEHistory = e;

        if (allowedEditable) {
            if (document.querySelector('.k2editableContent.active')) {
                document.querySelector('.k2editableContent.active').classList.remove('active');
            }

            if (this.classList.contains('k2editableHtml')) {
                console.log(document.getSelection().anchorNode)
                if (document.getSelection().anchorNode.tagName) {
                    if (document.getSelection().anchorNode.tagName.toLowerCase() == "img") {
                        var el = document.getSelection().anchorNode;
                        var range = document.createRange();
                        var sel = window.getSelection();
                        range.setStartAfter(el);
                        range.collapse(true);
                        sel.removeAllRanges();
                        sel.addRange(range);

                    }
                }

                controler.classList.add('active');
                var editablePosition = this.getBoundingClientRect(),
                    widthEditable = editablePosition.width + 8,
                    itemsImage = "",
                    imageEditable = this.getAttribute('k2editableimages');

                var editorType = this.getAttribute("k2editortype");
                if (editorType == "code") {
                    controler.querySelector(".codeEditor_button").classList.add("active");
                    controler.querySelector(".visualEditor_button").classList.remove("active");
                } else if (editorType == "visual") {
                    controler.querySelector(".codeEditor_button").classList.remove("active");
                    controler.querySelector(".visualEditor_button").classList.add("active");
                }

                if (imageEditable) {
                    imageEditable = imageEditable.split('|');
                    for (i = 0; i < imageEditable.length; i++) {
                        itemsImage += '<div class="gallery_item_edit"><button title="Obrázek" class="editable_btn" data-elem="#images_pop" data-type="insertimage" data-value="' + imageEditable[i] + '?w=1920"><img src="' + imageEditable[i] + '"></button></div>'
                    }
                } else {
                    itemsImage = "<h2>Nebyl nalezen žádný obrázek</h2>"
                }

                document.querySelector('.gallery_grid_edit').innerHTML = itemsImage;

                controler.style.width = widthEditable + "px";

                if (widthEditable <= 600 && document.querySelector("main")) {
                    var wrap = (this.closest(".wrap")) ? this.closest(".wrap") : document.querySelector("main");
                    var computedStyle = getComputedStyle(wrap);
                    controler.style.width = ((wrap.clientWidth || document.querySelector("main").clientWidth) - parseFloat(computedStyle.paddingLeft) - parseFloat(computedStyle.paddingRight)) + "px";
                }

                var controlerHeight = controler.offsetHeight,
                    topEditable = editablePosition.top + window.pageYOffset - controlerHeight - 3,
                    leftEditable = editablePosition.left - 4;

                controler.style.left = leftEditable + "px";
                controler.style.top = topEditable + "px";
                controler.style.width = widthEditable + "px";
                controler.style.position = "absolute";

                if (widthEditable <= 600 && document.querySelector("main")) {
                    let padding = parseFloat(computedStyle.paddingLeft);
                    let mainLeft = (wrap.getBoundingClientRect().left) + padding;
                    let fieldLeft = document.querySelector(".html_wrap.k2editableContent.k2editableHtml").getBoundingClientRect().left;
                    let posX = fieldLeft - mainLeft - 7;
                    let tolerance = 5;
                    controler.style.width = ((wrap.clientWidth) - padding - parseFloat(computedStyle.paddingRight)) - tolerance + "px";
                    controler.style.left = controler.getBoundingClientRect().left - posX + "px";
                }
                controler.querySelector(".editable_editorSwitch_wrap").classList.remove("bottom");

                triggerRange();
            } else {
                controler.classList.remove('active');
            }


            if (this.hasAttribute("k2editortype")) {
                if (!(this.getAttribute("k2editortype") == "code")) {
                    if (e.target.closest(".layoutContent")) {
                        if (!e.target.closest(".layoutContent").classList.contains("active")) {

                            e.target.closest(".layoutContent").querySelectorAll(".layout_item, .contenteditable").forEach(function (item) {
                                item.setAttribute("contenteditable", "true");
                            });
                            document.querySelectorAll(".layoutContent.active").forEach(function (item) {
                                item.classList.remove("active");
                            });
                            e.target.closest(".layoutContent").classList.add("active");
                            e.target.closest(".layoutContent").removeAttribute("contenteditable");

                            this.removeAttribute("contenteditable");

                            e.target.focus();
                        }
                        var layoutItem = e.target.closest(".layout_item, .contenteditable");
                        var layoutEdit = document.querySelector(".edit_layout");

                        document.querySelectorAll(".layout_item.active, .contenteditable.active").forEach(function (item) {
                            item.classList.remove("active")
                        });

                        if (layoutItem) {
                            layoutItem.classList.add("active");
                            layoutEdit.querySelector('input[name="paddingTop"]').value = layoutItem.style.paddingTop.replace("px", "") || 0;
                            layoutEdit.querySelector('input[name="paddingBottom"]').value = layoutItem.style.paddingBottom.replace("px", "") || 0;
                            layoutEdit.querySelector('input[name="paddingLeft"]').value = layoutItem.style.paddingLeft.replace("px", "") || 0;
                            layoutEdit.querySelector('input[name="paddingRight"]').value = layoutItem.style.paddingRight.replace("px", "") || 0;

                            if (!document.querySelector(".k2editableContent.active img.active"))
                                floatElementToElement(layoutEdit, layoutItem);
                        }


                    } else {
                        if (this.querySelector(".layoutContent")) {
                            this.querySelectorAll(".layout_item, .contenteditable").forEach(function (item) {
                                item.removeAttribute("contenteditable");
                                item.classList.remove("active");
                            });
                            this.querySelectorAll(".layoutContent").forEach(function (item) {
                                item.classList.remove("active");
                                item.setAttribute("contenteditable", "false");
                            });
                            document.querySelector(".edit_layout").classList.remove("active");
                        }

                        this.setAttribute("contenteditable", "true");
                        this.focus();
                    }

                }
            } else {
                this.setAttribute("contenteditable", "true");
                this.focus();
            }

            this.classList.add('active');

            document.dispatchEvent(new Event('scroll'));
            existHash();
            styleSelection();
            saveSelection();

        }
    });


    // editace datetime
    q('.k2editableDatetime', 'click', function () {
        var elementFloat = document.querySelector('.editable_datetime'),
            inputDateTime = document.querySelector('#dateTimeEditable'),
            elementClick = this,
            inputDay = document.querySelector('#daySet'),
            inputMonth = document.querySelector('#monthSet'),
            inputYear = document.querySelector('#yearSet'),
            inputHour = document.querySelector('#hourSet'),
            inputMinute = document.querySelector('#minuteSet'),
            dateTime = elementClick.textContent,
            date,
            time;


        dateTime = dateTime.split(" ");
        date = dateTime[0];
        time = dateTime[1];


        if (time === undefined) {
            var currentdate = new Date();
            hour = currentdate.getHours();
            minute = currentdate.getMinutes();
            second = 0;

            inputHour.value = hour;
            inputMinute.value = minute;

            time = hour + ":" + minute + ":" + second;

        } else {
            timeSplit = time.split(":");
            hour = timeSplit[0];
            minute = timeSplit[1];
            second = timeSplit[2];

            second === undefined ? second = 0 : false;

            inputHour.value = hour;
            inputMinute.value = minute;

            time = hour + ":" + minute + ":" + second;
        }

        if (date !== undefined) {
            date = date.split(".");
            day = parseInt(date[0]);
            month = parseInt(date[1]);
            year = parseInt(date[2]);

            inputDay.value = day;
            inputMonth.value = month;
            inputYear.value = year;

        }


        floatElementToElement(elementFloat, elementClick);
        elementClick.classList.add('active');
    });

    q('.datetime_change', 'change', dateTimeChange);
    q('.datetime_change', 'wheel', function (e) {
        e.preventDefault();
    });
    //q('.datetime_change', 'keyup', dateTimeChange);

    // střídaní třídy "active" na definovaný element (data-elem=".x") nebo na nasledujicí element (data-elem="next") a zaroven na elementu s třídou ".toggle_active"
    q('.toggle_active', 'click', function () {

        var selector = this.getAttribute('data-elem'),
            elemOpen = document.querySelector('.toggle_active.active');

        saveSelection();

        if ((elemOpen) && (elemOpen != this)) {
            elemOpen.click();
        }

        this.classList.toggle('active');
        if (selector != "next") {
            var el = document.querySelectorAll(selector),
                elLength = el.length;

            for (i = 0; i < elLength; i++) {
                el[i].classList.toggle('active');
            }
        } else {
            this.nextSibling.classList.toggle('active');
        }
        triggerRange();
    });

