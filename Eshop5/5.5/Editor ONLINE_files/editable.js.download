                                formatDoc('insertHTML', '<a href="' + sLnk + '" ' + classButton + '" title="' + linkTitle + '">' + sText + '</a>');
                            }
                        } else {
                            error("Vyberte prosím text");
                        }
                    } else if (sLnk.match(regex3)) {
                        classButton = createButton ? 'class="btn btn_normal js_favorite k2StyleEditor"' : 'class="js_favorite k2StyleEditor"';
                        console.log(classButton);
