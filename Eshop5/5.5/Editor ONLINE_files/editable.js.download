// formatovaní editované časti
function formatDoc(sCmd, sValue) {
    console.log("format");
    //document.execCommand("styleWithCSS", true, null);
    document.execCommand(sCmd, false, sValue);

    if (document.querySelector('.k2editableContent.active')) {
        var evt = new CustomEvent('keydown');
        document.querySelector('.k2editableContent.active').dispatchEvent(evt);
    }
    saveSelection();
    styleSelection();
}

// posuvník pro velikost pisma
function range(size, recalc) {
    if (document.querySelector('.js_range_edit')) {
        var t = document.querySelector('.js_range_edit'),
            wrap = t.querySelector('.range_wrap_edit'),
            wrapPositionLeft = wrap.getBoundingClientRect().left,
            maxMove = wrap.offsetWidth,
            hand = t.querySelector('.range_hand_edit'),
            rangeLine = t.querySelector('.range_line_edit'),
            input = t.querySelector('.range_input_edit'),
            min = parseInt(input.getAttribute('min')),
            max = parseInt(input.getAttribute('max')),
            value,
            percentStep = 100 / (max - min),
            accStep = 0,
            render = false,
            steps = [],
            values = [];

        if (!recalc) {
            for (i = 0; i <= (max - min); i++) {
                numb = percentStep * i;
                numb = parseFloat(numb.toFixed(2));
                steps.push(numb);
                values.push(min + i);
            }

            window.addEventListener('triggerRange', recalcRange, false);
            window.addEventListener('resize', recalcRange, false);

            addListenerMulti(hand, 'mousedown touchstart', function (event) {
                event.preventDefault();
                addListenerMulti(document, 'mousemove touchmove', moveHand);
                addListenerMulti(document, 'mouseup touchend', moveEnd);
            });
            addListenerMulti(hand, 'mouseup touchend', moveEnd);


            function moveEnd(event) {
                event.preventDefault();
                if (document.querySelector('.temp_editor')) {
                    document.querySelector('.temp_editor').removeAttribute('class');
                }
                document.removeEventListener("mousemove", moveHand, false);
                document.removeEventListener("touchmove", moveHand, false);
                document.removeEventListener("mouseup", moveEnd, false);
                document.removeEventListener("touchend", moveEnd, false);
            }

            function moveHand(event) {
                if ((typeof event.pageX !== "undefined")) {
                    event.preventDefault();
                    x = parseFloat(event.pageX - wrapPositionLeft);
                } else {
                    x = parseFloat(event.touches[0].clientX - wrapPositionLeft);
                }

                x < 0 ? x = 0 : false;
                x >= (maxMove) ? x = (maxMove) : false;

                position = (x / maxMove) * 100;
                position = parseFloat(position.toFixed(2));
                //console.log(position);


                if (position >= steps[accStep + 1]) {
                    accStep++;
                    render = true;
                } else if (position <= steps[accStep - 1]) {
                    accStep--;
                    render = true;
                }

                if (render) {
                    render = false;
                    //console.log(accStep);
                    value = values[accStep];
                    hand.setAttribute('style', 'left: ' + position + '% !important');
                    rangeLine.setAttribute('style', 'width: ' + position + '% !important');
                    //rangeLine.style.width = (position) + '%';
                    input.setAttribute('value', value);
                    restoreSelection();
                    formatDoc('fontsize', value);
                    saveSelection();
                }

            }

            function recalcRange(event) {
                wrapPositionLeft = wrap.getBoundingClientRect().left;
                maxMove = wrap.offsetWidth;
            }
        } else {
            /*hand.style.left = ((percentStep * size) - percentStep) + '%';
            rangeLine.style.width = ((percentStep * size) - percentStep) + '%';
*/

            hand.setAttribute('style', 'left: ' + ((percentStep * size) - percentStep) + '% !important');
            rangeLine.setAttribute('style', 'width: ' + ((percentStep * size) - percentStep) + '% !important');
            input.setAttribute('value', size);
            //accStep =
        }

    }
}

// zmena velikosti obrazku a vide
function imageVideoResize() {
    var element,
        positionImg,
        topImage,
        leftImage,
        widthImage,
        heightImage,
        ratioImage,
        widthParenth,
        imageSet = document.querySelector('.image_set_edit'),
        imageSetHand = document.querySelector('.image_set_edit .point_move_edit'),
        resize = false,
        isreverse_edit = false;


    addListenerMulti(imageSetHand, 'mousedown touchstart', function (event) {
        addListenerMulti(document, 'mousemove touchmove', resizeImgStart);
        addListenerMulti(document, 'mouseup touchend', resizeImgStop);
    });
    addListenerMulti(imageSetHand, 'mouseup touchend', resizeImgStop);


    function resizeImgStop() {
        document.querySelector('html').style.cursor = null;
        document.removeEventListener("mousemove", resizeImgStart, false);
        document.removeEventListener("touchmove", resizeImgStart, false);

        document.removeEventListener("mouseup", resizeImgStop, false);
        document.removeEventListener("touchend", resizeImgStop, false);

        imageSetHand.removeEventListener("mouseup", resizeImgStop, false);
        imageSetHand.removeEventListener("touchend", resizeImgStop, false);


        resize = false;
        isNeedSave();
        contentEditableElem = document.querySelector('.k2editableContent.active');
        if (contentEditableElem) {
            contentEditableElem.classList.add('k2editableContentChanged');
        }
    }

    function resizeImgStart(event) {
        event.preventDefault();
        if (!resize) {
            element = document.querySelector('.k2editableContent img.active') || document.querySelector('.k2editableContent .editable_video_content.active');
            positionImg = element.getBoundingClientRect();
            styleImage = element.currentStyle || window.getComputedStyle(element);
            imageFloat = styleImage.cssFloat;

            if (imageFloat === "right") {
                imageSetHand.classList.add('reverse_edit');
                isreverse_edit = true;
            } else {
                imageSetHand.classList.remove('reverse_edit');
                isreverse_edit = false;
            }

            widthImage = positionImg.width;
            heightImage = positionImg.height;
            ratioImage = widthImage / heightImage;
            widthParent = element.parentElement.nodeName === "A" ? element.parentElement.parentElement.offsetWidth : element.parentElement.offsetWidth;
            resize = true;
        }

        positionImg = element.getBoundingClientRect();
        topImage = positionImg.top + window.pageYOffset;
        leftImage = positionImg.left;


        if ((typeof event.pageX !== "undefined")) {
            if (isreverse_edit) {
                width = parseFloat(positionImg.width + (leftImage - event.pageX));
            } else {
                width = parseFloat(event.pageX - leftImage);
            }
        } else {
            if (isreverse_edit) {
                width = parseFloat(positionImg.width + (leftImage - event.touches[0].clientX));
            } else {
                width = parseFloat(event.touches[0].clientX - leftImage);
            }
        }


        width < 200 ? width = 200 : false;
        width > widthParent ? width = widthParent : false;
        height = width / ratioImage;
        element.style.width = width + 'px';
        element.style.height = 'auto';

        if (isreverse_edit) {
            imageSet.style.width = width + 'px';
            imageSet.style.height = height + 'px';
            imageSet.style.right = ((window.outerWidth - (window.innerWidth - document.querySelector('html').clientWidth)) - positionImg.right) + 'px';
            imageSet.style.left = null;
            imageSet.style.top = topImage + 'px';
            document.querySelector('html').style.cursor = "ne-resize";
        } else {
            document.querySelector('html').style.cursor = "nw-resize";
            imageSet.style.width = width + 'px';
            imageSet.style.height = height + 'px';
            imageSet.style.left = leftImage + 'px';
            imageSet.style.top = topImage + 'px';
        }

    }

}

// sticky controleru
function stickyControler() {
    var widthWindow = window.innerWidth,
        elem = document.elementFromPoint((widthWindow / 2), 1),
        styleElem,
        positionCssElem,
        elemHeight,
        headerHeight;
    console.log(elem.parentElement)
    console.log(elem.parentElement)
    while (true) {

        if (elem.nodeName === "HTML" || elem.parentElement.nodeName === "BODY") {
            break;
        }
        elem = elem.parentElement;

    }

    styleElem = elem.currentStyle || window.getComputedStyle(elem);
    positionCssElem = styleElem.position;
    //elemHeight = (positionCssElem === "fixed") ? elem.offsetHeight : 0;
    elemHeight = 0;

    window.addEventListener("resize", function () {
        styleElem = elem.currentStyle || window.getComputedStyle(elem);
        positionCssElem = styleElem.position;
        // elemHeight = (positionCssElem === "fixed") ? elem.offsetHeight : 0;
        elemHeight = 0;
        headerHeight = elem.offsetHeight;
    });


    document.addEventListener("scroll", function (e) {

        if (controler.classList.contains('active')) {
            var controlerRect = controler.getBoundingClientRect(),
                offsetTopControler = controlerRect.top,
                editableContent = document.querySelector('.k2editableContent.active'),
                editableRect = editableContent.getBoundingClientRect(),
                editableTop = editableRect.top + window.pageYOffset - controlerRect.height - 3,
                editablebottom = editableTop + editableRect.height + 7 + controlerRect.height,
                positionTop = editableRect.top - elemHeight - controlerRect.height - 28,
                stopControl = editableRect.top + editableRect.height - elemHeight - controlerRect.height - 28,
                positionEditableContent = editableRect.top - elemHeight - controlerRect.height,
                positionBottom = editableRect.top - window.innerHeight + editableRect.height,
                controlerTopFit = editableRect.top + window.pageYOffset - elemHeight - controlerRect.height - 28;


            if ((positionTop < 0) && (stopControl > 0)) {
                if (positionBottom + controlerRect.height >= 0) {
                    // Bottom viewportu se nachází v editable elementu
                    if (controlerTopFit > 0) {
                        controler.style.top = elemHeight + "px";
                        controler.querySelector(".editable_editorSwitch_wrap").classList.add("bottom");
                    } else {
                        controler.style.top = (window.innerHeight - controlerRect.height) + "px";
                        controler.querySelector(".editable_editorSwitch_wrap").classList.remove("bottom");
                    }
                    controler.style.position = "fixed";
                    controler.classList.add("sticky");
                } else {
                    // Bottom viewportu se nachází mimo editable elemet
                    controler.querySelector(".editable_editorSwitch_wrap").classList.add("bottom");
                    controler.style.top = editablebottom + "px";
                    controler.style.position = "absolute";
                    controler.classList.add("sticky");
                }
            } else if ((positionEditableContent > 0) && (controler.classList.contains('sticky')) && (stopControl > 0)) {
                controler.querySelector(".editable_editorSwitch_wrap").classList.remove("bottom");
                controler.style.top = editableTop + "px";
                controler.style.position = "absolute";
                controler.classList.remove("sticky");
            } else if (stopControl < 0) {
                controler.querySelector(".editable_editorSwitch_wrap").classList.add("bottom");
                controler.style.top = editablebottom + "px";
                controler.style.position = "absolute";
                controler.classList.remove("sticky");
            }
        }
    }, false);
}

// zobrazení chyby
function error(text) {
    var errorElm = document.querySelector('.error_edit'),
        textElm = document.querySelector('#textError');

    textElm.innerHTML = text;
    if (timerError === null) {
        errorElm.classList.add('active');
        timerError = setTimeout(err, 3000);
    } else {
        clearTimeout(timerError);
        timerError = null;
        timerError = setTimeout(err, 3000);
    }

    function err() {
        errorElm.classList.remove('active');
        clearTimeout(timerError);
        timerError = null;
    }
}


/*START pomocné funkce START*/

function getSelectionParentElement() {
    var parentEl = null,
        sel;
    sel = window.getSelection();
    if (sel.rangeCount) {
        parentEl = sel.getRangeAt(0).commonAncestorContainer;
        if (parentEl.nodeType != 1) {
            parentEl = parentEl.parentNode;
        }
    }

    return parentEl;
}

function isElement(e, selector) {
    var target = e.target

    while (target && target.parentElement !== document) {

        if (!target) {
            return false;
        }

        if (target.classList.contains(selector)) {
            return target;
        }

        target = target.parentElement;
    }
}



function setCaretOnlyText(el, position) {
    var range = document.createRange();
    var sel = window.getSelection();
    range.setStart(el.childNodes[0], position);
    range.collapse(true);
    sel.removeAllRanges();
    sel.addRange(range);
    el.focus();
}

function selectElement(node) {
    var sel = window.getSelection(),
        range = document.createRange();
    range.selectNode(node);
    sel.removeAllRanges();
    sel.addRange(range);
}

function quantitySelection() {
    if (window.getSelection) {
        start = window.getSelection().anchorOffset;
        end = window.getSelection().extentOffset;

        result = end - start;

        return result == 0 ? false : true;
    }
}

function saveSelection() {
    if (window.getSelection) {
        if (window.getSelection().anchorNode != null) {
            savedRange = window.getSelection().getRangeAt(0);
        }
    } else if (document.selection) {
        savedRange = document.selection.createRange();
    }
}

function restoreSelection() {
    if (savedRange != null) {
        //console.log(savedRange);
        if (window.getSelection) {
            var s = window.getSelection();
            if (s.rangeCount > 0)
                s.removeAllRanges();
            s.addRange(savedRange);
        } else if (document.createRange) {
            window.getSelection().addRange(savedRange);
        } else if (document.selection) {
            savedRange.select();
        }
    }
}

function removeSelection() {
    var s = window.getSelection();
    if (s.rangeCount > 0)
        s.removeAllRanges();
}

function createTable(r, c, h) {
    var table = '<div style="max-width: 100%;overflow-x: auto;overflow-y:hidden;white-space:nowrap;" class="table_wrapper"><table class="edit_table">';
    for (x = 0; x < r; x++) {
        row = '<tr>';
        for (y = 0; y < c; y++) {
            if (h && (x == 0)) {
                row = row + '<th><br></th>';
            } else {
                row = row + '<td><br></td>';
            }
        }
        row = row + '</tr>';
        table = table + row;
    }
    table = table + '</table></div><br>';
    return table;
}

function q(elClass, action, fn) {
    var el = document.querySelectorAll(elClass),
        elLength = el.length;

    for (i = 0; i < elLength; i++) {
        el[i].addEventListener(action, fn, false);
    }
}

function addListenerMulti(element, eventNames, listener) {
    //console.log(element);
    if (element) {
        var events = eventNames.split(' ');
        for (var i = 0, iLen = events.length; i < iLen; i++) {
            element.addEventListener(events[i], listener, false);
        }
    }
}

function triggerRange() {
    var evt = new CustomEvent('triggerRange');
    window.dispatchEvent(evt);
}

function floatElementToElement(elementFlaot, elementTarget) {
    console.log(elementFlaot);
    var positionElmTarget = elementTarget.getBoundingClientRect();

    elementFlaot.classList.add('active');
    topEditLink = positionElmTarget.top + positionElmTarget.height + window.pageYOffset;
    leftEditLink = positionElmTarget.left + (positionElmTarget.width / 2) - (elementFlaot.offsetWidth / 2);

    elementFlaot.style.left = leftEditLink + "px";
    elementFlaot.style.top = topEditLink + "px";
}

function getComputedStyleProperty(el, propName) {
    if (window.getComputedStyle) {
        return window.getComputedStyle(el, null)[propName];
    } else if (el.currentStyle) {
        return el.currentStyle[propName];
    }
}

function styleSelection() {
    var el = document.querySelectorAll('.set_active'),
        elLength = el.length,
        formatValue = document.queryCommandValue('formatblock'),
        fontSizeValue = document.queryCommandValue('fontsize'),
        colorValue = document.queryCommandValue('forecolor');

    if (!(fontSizeValue >= 1 && fontSizeValue <= 7)) {
        var containerEl, sel;
        if (window.getSelection) {
            sel = window.getSelection();
            if (sel.rangeCount) {
                containerEl = sel.getRangeAt(0).commonAncestorContainer;
                // Make sure we have an element rather than a text node
                if (containerEl.nodeType == 3) {
                    containerEl = containerEl.parentNode;
                }
            }
        } else if ((sel = document.selection) && sel.type != "Control") {
            containerEl = sel.createRange().parentElement();
        }

        if (containerEl) {
            fontSizeValue = getComputedStyleProperty(containerEl, "fontSize");
            // var colour = getComputedStyleProperty(containerEl, "color");
        }
        switch (fontSizeValue) {
            case "10px":
                fontSizeValue = 1;
                break;
            case "13px":
                fontSizeValue = 2;
                break;
            case "16px":
                fontSizeValue = 3;
                break;
            case "18px":
                fontSizeValue = 4;
                break;
            case "24px":
                fontSizeValue = 5;
                break;
            case "32px":
                fontSizeValue = 6;
                break;
            case "48px":
                fontSizeValue = 7;
                break;
            default:
                fontSizeValue = 2;
                break;
        }
    }

    range(fontSizeValue, true);

    for (i = 0; i < elLength; i++) {
        var elem = el[i],
            type = elem.getAttribute('data-type'),
            value = elem.getAttribute('data-value');

        elem.classList.remove('active_style');


        if (type == "formatblock") {
            if (value == formatValue) {
                elem.classList.add('active_style');
            }
        } else if (type == "forecolor") {
            if (value == colorValue) {
                elem.classList.add('active_style');
            }
        } else {
            if (document.queryCommandState(type)) {
                elem.classList.add('active_style');
                //console.log(elem);
                //console.log(type);
            }
        }
    }

    /*queryCommandValue('formatblock')*/

    //console.log(document.queryCommandState('formatblock'));


    //console.log(document.queryCommandValue('forecolor'));
    //console.log(document.queryCommandState('italic'));
}

/*END pomocné funkce END*/


/* START Ukládání START */
function saving() {
    document.querySelector('.editable_save').addEventListener('click', function (e) {
        e.preventDefault();
        console.log('saving');
        document.querySelectorAll('.k2editableContent').forEach(function (el) {
              el.querySelectorAll('.editable_video_content').forEach(function (t) {
                iframe = t.querySelector('iframe');
                iframe.dataset.src = iframe.src;
                iframe.dataset.k2Consent = "marketing";
                iframe.removeAttribute('src');
            });

            toVisualEditor(el);
            removeLayoutActive(el)
        });

        document.querySelectorAll('.k2editableContentChanged [style]').forEach(function (element) {
            element.classList.add('k2StyleEditor');
        });
        document.querySelector('#k2editableSave').click();
    }, false)

    document.querySelector('.saving_editable').addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector('.saving_editable').classList.remove('active');
    }, false)


    var timerSaveMsg = null;

    $(document).on('k2trigger', function (e, data) {

        console.log(data);
        if ((data.modul == "k2editable")) {
            if ((data.action == "save") && (data.state == "start")) {
                document.querySelector('.editable_save').style.transition = "none";
                document.querySelector('.editable_save').style.opacity = "0";
                document.querySelector('.editable_save').setAttribute('disabled', '');
                document.querySelector('.saving_editable').classList.add('active');

            } else if ((data.action == "save") && (data.state == "end")) {
                document.querySelector('.editable_save').style.transition = "";
                document.querySelector('.editable_save').style.opacity = "";
                if (!data.fail) {
                    document.querySelector('.saving_editable').classList.remove('active');

                    window.onbeforeunload = null;
                    needSave = false;

                    document.querySelector('.saving_editable').classList.add('active', 'save_done');

                    timerSaveMsg = setTimeout(function () {
                        document.querySelector('.saving_editable').style.opacity = "0";
                        setTimeout(function () {
                            document.querySelector('.saving_editable').classList.remove('active', 'save_done');
                            document.querySelector('.saving_editable').style.opacity = "";
                            if (editingInK2) {
                                disableEditInK2();
                            }
                        }, 300);
                        clearTimeout(timerSaveMsg);
                    }, 2500);

                } else {
                    document.querySelector('.saving_editable').classList.remove('active');
                    console.log('ChYBA');
                }
                document.querySelectorAll('.k2editableContent').forEach(function (el) {
                    el.querySelectorAll('.editable_video_content').forEach(function (t) {
                        iframe = t.querySelector('iframe');
                        iframe.src = iframe.dataset.src;
                    });
                });
            }

        }
    });
}

/* END Ukládání END*/
