const defineHtmlEditor = {
    js: {
        equa: /(\b=\b)/g,
        quot: /(`|'|"|&#39;|&#34;)/g,
        comm: /((\/\*([^*]|[\r\n]|(\*+([^*/]|[\r\n])))*\*+\/)|(\/\/.*))/g,
        logi: /(%=|%|\-|\+|\*|&amp;{1,2}|\|{1,2}|&lt;=|&gt;=|&lt;|&gt;|!={1,2}|={2,3})/g,
        numb: /(\d+(\.\d+)?(e\d+)?)/g,
        func: /(?<=^|\s*)(async|console|alert|Math|Object|Array|String|class(?!\s*\=)|function|(?<=\.)\D\w*)(?=\b)/g,
        decl: /(?<=^|\s*)(var|let|const)/g, // Declarations
        pare: /(\(|\))/g,
        squa: /(\[|\])/g,
        curl: /(\{|\})/g,
    },
    html: { 
        tags: /(?<=&lt;(?:\/)?)(\w+)(?=\s|\&gt;)/g,
        angl: /(&lt;\/?|&gt;)/g,
        attr: /((?<=<i class=html_tags>\w+<\/i>)[^<]+)/g,
    }
};

