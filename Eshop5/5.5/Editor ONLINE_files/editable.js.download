                    //     textRange.collapse(false);
                    //     textRange.select();
                    // } else {
                    restoreSelection();
                    formatDoc("insertHTML", '<img loading="lazy" src="' + value + '">');
                    // }

                } else {
                    formatDoc(type);
                }

                if (document.querySelector('.controler_btn.active')) {
                    document.querySelector('.controler_btn.active').click();
                }
                if (popup) {
                    popup.querySelector('.btn_pop').click();
                }
            }
        }
        
        var el = document.querySelector('.k2editableContent.active');
        if (e.target.closest(".editable_control.active .codeEditor_button:not(.active)")) {
            toCodeEditor(el);
            document.querySelector(".k2editableContent.k2editableHtml.active").click();
            checkTypeEditorBtns(el);
            document.dispatchEvent(new Event('scroll'));
        }
        if (e.target.closest(".editable_control.active .visualEditor_button:not(.active)")) {
            toVisualEditor(el);
            document.querySelector(".k2editableContent.k2editableHtml.active").click();
            checkTypeEditorBtns(el);
            document.dispatchEvent(new Event('scroll'));
        }
    }, false);

    function checkTypeEditorBtns(el) {
        var editorType = el.getAttribute("k2editortype");
        if (editorType == "code") {
            controler.querySelector(".codeEditor_button").classList.add("active");
            controler.querySelector(".visualEditor_button").classList.remove("active");
        } else if (editorType == "visual") {
            controler.querySelector(".codeEditor_button").classList.remove("active");
            controler.querySelector(".visualEditor_button").classList.add("active");
        }
    }


    //zobrazení kotev
    visibleHash();


    // přichycení controleru
    stickyControler();


    // při psaní v editovaných blocích
    writeInContent();


    // volaní posuvníku pro velikost písma
    range(false, false);


    // editace odkazu v editované časti a obrázky
    document.addEventListener("click", function (e) {
        var target = e.target;

        if (document.querySelector('.k2editableContent table td.active')) {
            document.querySelector('.k2editableContent table td.active').removeAttribute('class');
        } // false


        while (target && target.parentNode !== document) {
            if (!target) {
                return;
            }

            // muže platit více podmínek?
            if (target.nodeName === "A") {
                if (target.closest('.k2editableContent')) {
                    editLink(target);
                    break;
                }
            } else if (target.nodeName === "IMG") {
                if (target.closest('.k2editableContent')) {
                    clickImageVideo(target);
                    break;
                }
            } else if ((target.nodeName === "TD") || target.nodeName === "TH" || target.classList.contains("active_resize")) {
                if (target.closest('.k2editableContent')) {
                    editTable(target);
                    break;
                }
            } else if (target.closest('.editable_video_content')) {
                clickImageVideo(target);
                break;
            }

            target = target.parentNode;

        }


    });


}

//V daném K2 Editoru zruší všechny aktivní layouty
function removeLayoutActive(el) {

    if (el.querySelector(".layoutContent")) {
        el.querySelectorAll(".layout_item, .contenteditable").forEach(function (item) {
            item.removeAttribute("contenteditable");
            item.classList.remove("active");
        });
        el.querySelectorAll(".layoutContent").forEach(function (item) {
            item.classList.remove("active");
            item.removeAttribute("contenteditable");
        });
    }

}


function highLite(el) {
    const dataLang = 'html';//el.dataset.lang;
    const langObj = defineHtmlEditor[dataLang];
    let html = el.innerHTML;
    Object.keys(langObj).forEach(function (key) {
        html = html.replace(langObj[key], `<i class=${dataLang}_${key}>$1</i>`);
    });
    el.previousElementSibling.innerHTML = html;
}

///\s+( <+)*$/g
function escapeHTML(html) {
    html = html.replaceAll(/\n/g, "&#10;");
    html = html.replaceAll('°/°', ' ');
    html = html.replaceAll('>', '&gt;');
    html = html.replaceAll('<', '&lt;');
    //console.log(html);
    return html;
}

function unescapeHTML(html) {
    html = html.replaceAll("&#10;", "");
    html = html.replaceAll('&gt;', '>');
    html = html.replaceAll('&lt;', '<');
    html = html.replace(/\>[\r\n ]+\</g, "><").trim();
    //console.log(html);
    return html;
}

//Převede obsah editoru do textararee pro HTML edit..
function toCodeEditor(el) {
    if (el.getAttribute("k2editortype") == "visual" || !el.hasAttribute("k2editortype")) {
        el.setAttribute("k2editortype", "code");
        el.setAttribute("contenteditable", "false");
        test = formatHtml(el, 0, true).innerHTML;
        //console.log(test);
        test = escapeHTML(test);
        //console.log(escapeHTML(test));
        el.innerHTML = '<div class="code_color"></div><div data-lang="html" id="code" autocomplete="off" spellcheck="off" autocorrect="off" autocapitalize ="off" contenteditable>' + test + '</div>';

        el.querySelector("#code").addEventListener("input", highLite.bind(null, el.querySelector("#code")));
        el.querySelector("#code").addEventListener("input", highLite.bind(null, el.querySelector("#code")));
        highLite(el.querySelector("#code")); // Init!
        el.querySelector("#code").style.minHeight = (el.querySelector("#code").scrollHeight + 30) + "px";
        controler.querySelector(".editable_control_wrap").classList.add("hide");

        var editableContent = document.querySelector('.k2editableContent.active'),
            editableRect = editableContent.getBoundingClientRect(),
            editableTop = editableRect.top + window.pageYOffset - controler.offsetHeight - 3;


        if (controler.classList.contains("sticky")) controler.style.top = 0 + "px";
        else controler.style.top = editableTop + "px";

        return true;
    } else return false;
}


function formatHtml(node, level, newFormating) {
    var indentBefore = new Array(level++ + 1).join('    '),
        indentAfter = new Array(level - 1).join('    '),
        textNode;


    for (var i = 0; i < node.children.length; i++) {
        textNode = document.createTextNode('\n' + indentBefore);
        node.insertBefore(textNode, node.children[i]);

        formatHtml(node.children[i], level);

        if (node.lastElementChild == node.children[i]) {
            textNode = document.createTextNode('\n' + indentAfter);
            node.appendChild(textNode);
        }
    }

    return node;
}

//Převede obsah textarey do obsahu editoru pro klasický vizuální vzhled HTML.
function toVisualEditor(el) {
    if (el.getAttribute("k2editortype") == "code") {
        el.setAttribute("contenteditable", "true");
        el.setAttribute("k2editortype", "visual");
        // console.log(el.querySelector("#code").value);
        te = unescapeHTML(el.querySelector("#code").innerText);
        el.innerHTML = te;//.replace(/\>[\r\n ]+\</g, "><").trim();
        controler.querySelector(".editable_control_wrap").classList.remove("hide");
        document.execCommand("defaultParagraphSeparator", false, "p");
        editableRect = el.getBoundingClientRect(),
            editableTop = editableRect.top + window.pageYOffset - controler.offsetHeight - 3;

        if (controler.classList.contains("sticky")) controler.style.top = 0 + "px";
        else controler.style.top = editableTop + "px";

        tables = Array.from(document.querySelectorAll(".table_wrapper"));
    } else return false;
}
function switchEditorType(isCodeEditor){  //pro webovou k2
    var el = document.querySelector('.k2editableContent.active');
    if(!el){
        document.querySelector(".k2editableContent").click();//activate        el = document.querySelector('.k2editableContent.active');
    }
    if(el){        
        if (isCodeEditor) {
            toCodeEditor(el);
            document.dispatchEvent(new Event('scroll'));
        }else{
            toVisualEditor(el);
            document.dispatchEvent(new Event('scroll'));
        }
        let margin = document.querySelector('.editable_control').offsetHeight;
        if(!window.webK2)
            margin+= 30;
        else            margin += 10;
            el.setAttribute('style', 'margin-top:'+ margin +'px !important');
    }
}
function existHash() {
    var el = document.querySelector('.k2editableContent.active');
    if (el.querySelector('.k2StyleEditor[id]')) {
        document.querySelector('.visible_hash_content').classList.remove('hidden');
    } else {
        document.querySelector('.visible_hash_content').classList.add('hidden');
    }
}

function visibleHash() {
    document.getElementById('visibleHash').addEventListener('change', function () {
        if (this.checked) {
            // je active
            var editActiveEl = document.querySelector('.k2editableContent.active')
            if (editActiveEl) {
                editActiveEl.classList.add('active_hash');
                editActiveEl.removeAttribute('contenteditable');
            }
            removeSelection();
            allowedEditable = false;
            settingHash(true);
        } else {
            // neni active
            var activeHashEl = document.querySelector('.k2editableContent.active_hash');
            if (activeHashEl) {
                activeHashEl.classList.remove('active_hash');
            }
            allowedEditable = true;
            settingHash(false);
            document.querySelector('.editable_hash').classList.remove('active');
        }

    }, false);

    hashControl();
}

//editace kotev
function hashControl(newElement) {
    var moveActive = false;
    //console.log(active);
    if (newElement) {
        newElement.addEventListener('mousedown', startMoveHash, true);
    } else {
        document.querySelectorAll('.k2StyleEditor[id]').forEach(function (r) {
            r.addEventListener('mousedown', startMoveHash, true);
        });
    }


    function startMoveHash(event) {
        //thisActive = document.elementFromPoint((widthWindow / 2), event.clientY);
        this.classList.add('move');
        moveActive = true;
        document.querySelector('.editable_hash').classList.remove('active');
        document.addEventListener('mousemove', MoveHash, false);
        document.addEventListener('mouseup', StopMoveHash, false);
    }

    function MoveHash(event) {
        var activeContentEditable = document.querySelector('.k2editableContent.active');
        var hash = document.querySelector('.k2StyleEditor.move');
        var thisActive = document.elementFromPoint(activeContentEditable.getBoundingClientRect().left, event.clientY);
        var eleMove = thisActive.closest('.k2editableContent > *');
        //console.log(thisActive);active.previousElementSibling;
        if (eleMove != null) {
            //if(!eleMove.previousSibling.classList.contains('k2StyleEditor')){
            eleMove.before(hash);
            //}
        }
    }

    function StopMoveHash() {
        document.removeEventListener('mousemove', MoveHash, false);
        document.removeEventListener('mouseup', StopMoveHash, false);
        if (document.querySelector('.k2StyleEditor.move')) {
            document.querySelector('.k2StyleEditor.move').classList.remove('move');
        }
        moveActive = false
        isNeedSave(document.querySelector('.k2editableContent.active'));
    }
}

function settingHash(visible) {
    document.querySelectorAll('.k2StyleEditor[id]').forEach(function (r) {
        var id = r.getAttribute('id');
        if (visible) {
            var settingButton = document.createElement('button');
            settingButton.classList.add("hash_setting");
            r.append(settingButton);
            settingButton.addEventListener('click', viewSetting, false);
        } else {
            r.innerHTML = "";
        }
    });

    function viewSetting(e) {
        e.stopPropagation();
        e.preventDefault();

        var el = document.querySelector('.editable_hash'),
            id = this.parentElement.getAttribute('id'),
            inputhash = document.querySelector('#HashNameEdit'),
            linkHash = document.querySelector('#linkHash');

        if (!this.classList.contains('active')) {
            linkHash.value = location.href.split('?')[0].split('#')[0] + "#" + id;
            inputhash.value = id;

            floatElementToElement(el, this);
            this.classList.add('active');
        } else {
            el.classList.remove('active');
            this.classList.remove('active');
        }
    }

}


function dateTimeChange(e) {
    e.preventDefault();
    var el = this,
        type = el.getAttribute('data-type'),
        elDay = document.querySelector('#daySet'),
        elMonth = document.querySelector('#monthSet'),
        elYear = document.querySelector('#yearSet'),
        hour = document.querySelector('#hourSet').value,
        minute = document.querySelector('#minuteSet').value,
        day = parseInt(elDay.value),
        month = parseInt(elMonth.value),
        year = parseInt(elYear.value);


    contentEditableElem = document.querySelector('.k2editableDatetime.active');
    contentEditableElem.classList.add('k2editableContentChanged');

    isNeedSave();

    checkValid(el)

    function checkValid(elem) {
        var value = parseInt(elem.value),
            min = elem.getAttribute('data-min'),
            max = elem.getAttribute('data-max');


        if ((isNaN(value)) || (value > max)) {
            elem.value = min;
            value = min;
        } else if (value < min) {
            elem.value = max;
            value = max;
        }

        hour = document.querySelector('#hourSet').value;
        minute = document.querySelector('#minuteSet').value;
        day = parseInt(elDay.value);
        month = parseInt(elMonth.value);
        year = parseInt(elYear.value);
        contentEditableElem.textContent = day + "." + month + "." + year;
        contentEditableElem.setAttribute("data-value", year + "-" + month + "-" + day + " " + hour + ":" + minute + ":0");
    }


    if (type == "date") {


        if (month == 2) {
            if (((year % 4 == 0) && (year % 100 != 0)) || (year % 400 == 0)) {
                elDay.setAttribute('data-max', 29);
            } else {
                elDay.setAttribute('data-max', 28);
            }
        } else if ((month == 4) || (month == 6) || (month == 9) || (month == 11)) {
            elDay.setAttribute('data-max', 30);
        } else {
            elDay.setAttribute('data-max', 31);
        }


        checkValid(elDay);



    }


}


