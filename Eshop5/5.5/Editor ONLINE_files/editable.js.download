function checkSize(img) {
    var loadingScreen = document.getElementById('loading-screen');
    loadingScreen.classList.remove('flex');
    if (img.naturalWidth < 20 || img.naturalHeight < 20) {
        error("Obrázek je příliš malý");
        img.remove();
        return;
    }
    //check if image is bigger than 2 MB
    if (img.naturalWidth * img.naturalHeight > (2 * 1024 * 1024)) {
        error("Obrázek je příliš velký");
        img.remove();
        return;
    }
    document.getElementById('img_url_input').value = '';
    restoreSelection();
    var popup = document.querySelector('.popup_edit_container.active');
    popup.querySelector('.btn_pop').click();


}
function removeThis(img) {
    var loadingScreen = document.getElementById('loading-screen');
    loadingScreen.classList.remove('flex');
    error("Obrázek se nepodařilo načíst");
    img.remove();
}
function addGalleryItem() {
    var url = document.getElementById('img_url_input').value;
    var loadingScreen = document.getElementById('loading-screen');
    // Show the loading screen
    loadingScreen.classList.add('flex');
    restoreSelection();
    // Insert the image
    formatDoc("insertHTML", '<img loading="lazy" onload="checkSize(this)" onerror="removeThis(this)" src="' + url + '">');
}





const inputElement = document.getElementById('img_url_input');

// Add an event listener for the "keydown" event
inputElement.addEventListener('keydown', (event) => {
  // Check if the "Enter" key was pressed (key code 13)
  if (event.key === 'Enter') {
    // Call a function to do something
    addGalleryItem();
  }
});

  
  
  
  



function disableEditInK2() {
    document.body.classList.remove('edit_in_k2_start')
    document.querySelector('.editable_main_set').classList.add('not_visible');
    //document.querySelector('.container_edit_for_k2').classList.remove('not_visible');
    var items = document.querySelectorAll('.k2editableContent');
    itemsLength = items.length;
    for (i = 0; i < itemsLength; i++) {
        items[i].classList.add('notEditable');
        items[i].contentEditable = false;
    }
    //location.reload();
}

