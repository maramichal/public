  $(document).on('click', '.k2fx5basketList .k2btnDel', function (e) {
    e.preventDefault();
    userBasketListDel($(this));
  });

  function userBasketListDel(btn) {
    var _modul = 'k2fx5basketList';
    var _action = 'save';
    var fce = btn.closest('.' + _modul);
    var item = btn.closest('[data-k2="item"]');
