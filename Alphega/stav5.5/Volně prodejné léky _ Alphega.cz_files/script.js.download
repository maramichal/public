function zipShipping(){
    var el = document.querySelector('[data-k2="delivery"] .k2ZIP');
    if(el){
        el.maxLength = 6;
        //el.type = "number";
        
        el.addEventListener('input', function(){
            var val = this.value.replaceAll(" ", "").replace(/\D/g, '');
            //console.error(val);
            if(val.length > 5){
                val = val.toString().substring(0, 5);
            }
            this.value = val;
        })
    }
}


