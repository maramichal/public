    var popupWrap = '<div class="popup hide" id="paymentConfirmationPopup"><div class="popup_bg popup_close_payment"></div><div class="popup_wrap spacing"><button class="ico ico-close popup_close_payment"><svg class="ico ico-close"><use xlink:href="#ico-close"></use></svg></button></div></div>';
